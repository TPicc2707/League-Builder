@page "/updateseason/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject ISeasonService SeasonService
@inject ITeamService TeamsService
@inject IStandingsService StandingsService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject ISnackbar Snackbar
@inject IValidator<UpdateSeasonModel> UpdateSeasonValidator
@inject IDialogService DialogService
@inject ISeasonLocalCacheService SeasonLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject IStandingsLocalCacheService StandingsLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService

<AuthorizeView Roles="@String.Concat(Roles.UpdateSeasons)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="pt-12">
                <MudPaper Class="border border-solid p-25" Style="border-color: #000000;">
                    <MudText Typo="Typo.h4" Align="Align.Center" Class="font-bold">Update Season</MudText>
                </MudPaper>
            </MudItem>
            <MudItem Class="mt-50 mb-50">
                <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                    <FluentValidationValidator @ref="fluentValidationValidator" />
                    <MudPaper Class="border border-solid p-25" Style="border-color: #000000; width: 100%;">
                        <MudStepper @bind-ActiveIndex="_index" OnPreviewInteraction="@OnStepInteraction" CurrentStepColor="Color.Secondary" CompletedStepColor="Color.Success">
                            <ChildContent>
                                <MudStep Title="Update Season Information">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.Info, "Season Information")
                                                <MudTextField Required Label="Season Year"
                                                              @bind-Value="model.Year" For="@(() => model.Year)" Clearable />
                                                <MudTextField Label="Description" Class="mt-3"
                                                              @bind-Value="model.Description" For="@(() => model.Description)" Clearable />
                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Review">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.RemoveRedEye, "Review")
                                                <MudTextField Required ReadOnly Label="Season Year"
                                                              @bind-Value="model.Year" For="@(() => model.Year)" />
                                                <MudTextField ReadOnly Label="Description" Class="mt-3"
                                                              @bind-Value="model.Description" For="@(() => model.Description)" />
                                            </div>,
                                            @<MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" FullWidth="true">Update</MudButton>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                            </ChildContent>
                            <ActionContent Context="stepper">
                                <MudIconButton OnClick="@(() => stepper.PreviousStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowBack"
                                               Color="Color.Primary"
                                               Disabled="_index == 0">
                                </MudIconButton>
                                <MudSpacer />
                                <MudIconButton OnClick="@(() => stepper.NextStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowForward"
                                               Color="Color.Primary"
                                               Disabled="_index == 1">
                                </MudIconButton>
                            </ActionContent>
                        </MudStepper>
                    </MudPaper>
                </EditForm>
            </MudItem>
        }
        else
        {
            <Loading />
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set;}

    UpdateSeasonModel model = new UpdateSeasonModel();
    bool isYearOver = false;
    private int _index;
    private bool canProceed = false;
    private List<string> errors = new();
    GetSeasonByIdResponse GetSeasonModel { get; set; }
    public bool PageLoad = false;
    private FluentValidationValidator fluentValidationValidator;
    private IJSObjectReference? _module;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var seasonId = Guid.Parse(Id);

            GetSeasonModel = await LoadSeasonAsync(seasonId);

            MapModel();

            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }

    }

    private void MapModel()
    {
        var s = GetSeasonModel.Season;

        model.Id = s.Id;
        model.Year = s.Year;
        model.Description = s.Description;

        isYearOver = model.Year < DateTime.Now.Year ? true : false;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        try
        {
            await SeasonService.UpdateSeason(new UpdateSeasonRequest(model.Id, model.Year, model.Description));
            await ClearCachesAsync();
            NavManager.NavigateTo("/seasons");
            Snackbar.Add("Season has been updated.", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task ClearCachesAsync()
    {
        await SeasonLocalCache.DeleteSeasonsCache();
        await SeasonLocalCache.DeleteSeasonByIdCache(model.Id.ToString());
        await SeasonLocalCache.DeleteSeasonByYearCache(model.Year);
    }

    private async Task OnStepInteraction(StepperInteractionEventArgs args)
    {
        canProceed = false;
        await ValidateCurrentStep();
        if (args.Action == StepAction.Complete && !canProceed)
        {
            await OpenErrorDialogAsync();
            args.Cancel = true;

        }
    }

    private async Task ValidateCurrentStep()
    {
        GetSeasonsResponse seasons;
        errors.Clear();

        var props = _index switch
        {
            0 => new[] { nameof(UpdateSeasonModel.Year) },
            _ => Array.Empty<string>()
        };


        seasons = await LoadSeasonsAsync();

        var doesSeasonExist = seasons.Seasons.Where(x => x.Year == model.Year).Any();

        var scopedSeason = GetSeasonModel.Season.Year == model.Year;

        if (doesSeasonExist && !scopedSeason)
            errors.Add("This season already exists.");

        var result = await UpdateSeasonValidator.ValidateAsync(model, options => options.IncludeProperties(props));

        if (result.IsValid && (!doesSeasonExist || scopedSeason))
            canProceed = true;

        foreach (var error in result.Errors)
            errors.Add($"{error.ErrorMessage}");

    }

    private Task OpenErrorDialogAsync()
    {
        var parameters = new DialogParameters<ErrorMessageBox> { { x => x.Errors, errors } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        return DialogService.ShowAsync<ErrorMessageBox>("Errors", parameters, options);
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private Task<GetSeasonsResponse> LoadSeasonsAsync() =>
        DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonsCache(),
            () => SeasonService.GetSeasons(),
            (s) => SeasonLocalCache.SetSeasonsCache(s)
    );


    private Task<GetSeasonByIdResponse> LoadSeasonAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonByIdCache(id.ToString()),
            () => SeasonService.GetSeason(id),
            (s) => SeasonLocalCache.SetSeasonByIdCache(id.ToString(), s)
    );

    private RenderFragment Card(RenderFragment content, RenderFragment actions = null) => @<MudCard Class="border border-solid border-black">
            <MudCardContent>
                @content
            </MudCardContent>
        @if (actions is not null)
        {
                <MudCardActions>
                    @actions
                </MudCardActions>
        }
    </MudCard>;

    private Func<string, string, RenderFragment> StepHeader = (string icon, string title) => @<MudStack Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Row="true">
        <MudIcon Icon="@icon" Color="Color.Secondary" Size="Size.Medium" />
        <MudText Typo="Typo.h6" Class="font-bold">@title</MudText>
    </MudStack>;
}

