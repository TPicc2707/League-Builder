@page "/seasons"
@using League.Builder.Web.Server.Services.Cache
@inject ISeasonService SeasonService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject IDialogService DialogService
@inject ISeasonLocalCacheService SeasonLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject AuthenticationStateProvider AuthenticationStateProvider

<AuthorizeView Roles="@Roles.CreateSeasons" Context="auth">
    <Authorized>
    @if (PageLoad)
    {
            <MudItem Class="pt-12">
                <MudPaper Class="border border-solid p-25" Style="border-color: #000000;">
                        <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight:bold">Seasons</MudText>
                </MudPaper>
            </MudItem>
            <MudItem Class="pt-6">
                <MudPaper Elevation="2" Class="border border-solid p-25" Style="border-color: #000000;">
                    <MudItem>
                        <MudTable Items="@Model.Seasons" Hover="true" SortLabel="Sort By" Class="border border-solid" Style="border-color: #000000;">
                            <ToolBarContent>
                                <MudStack Justify="Justify.FlexStart">
                                    <MudButton Href="/createseason/" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" style="width: 200px;">Create</MudButton>
                                </MudStack>
                            </ToolBarContent>
                            <HeaderContent>
                                <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<SeasonModel, object>(x => x.Year)">Year</MudTableSortLabel></MudTh>
                                <MudTh Class="mud-theme-primary"></MudTh>
                                <MudTh Class="mud-theme-primary"></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Team Name">@context.Year</MudTd>
                                @if (CanUpdateSeason)
                                {
                                    <MudTd DataLabel="Edit">
                                        <MudTooltip Text="Edit" Color="Color.Secondary">
                                            <MudLink Color="Color.Tertiary" Href="@($"/updateseason/{context.Id.ToString()}")">
                                                <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                            </MudLink>
                                        </MudTooltip>
                                    </MudTd>
                                }
                                else
                                {
                                    <MudTd></MudTd>
                                }
                                @if (CanDeleteSeason)
                                {
                                    <MudTd DataLabel="Delete">
                                        <MudTooltip Text="Delete" Color="Color.Secondary">
                                            <MudLink Color="Color.Tertiary" OnClick="@(() => OpenDialogAsync(context.Id))">
                                                <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                            </MudLink>
                                        </MudTooltip>
                                    </MudTd>
                                }
                                else
                                {
                                    <MudTd></MudTd>
                                }
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                </MudPaper>

            </MudItem>
    }
    else
    {
        <Loading />
    }

    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>
@code {

    private bool PageLoad = false;
    GetSeasonsResponse Model { get; set; }
    private bool expandSearchPanel = false;
    private IJSObjectReference? _module;
    private bool CanUpdateSeason;
    private bool CanDeleteSeason;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            Model = await LoadSeasonsAsync();

            CanUpdateSeason = user.IsInRole(Roles.UpdateSeasons);
            CanDeleteSeason = user.IsInRole(Roles.DeleteSeasons);

            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task OpenDialogAsync(Guid id)
    {
        var parameters = new DialogParameters<DeleteSeasonMessageBox> { { x => x.Id, id } };
        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = await DialogService.ShowAsync<DeleteSeasonMessageBox>("Delete Season", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Model = await LoadSeasonsAsync();
        }
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private async Task<GetSeasonsResponse> LoadSeasonsAsync() =>
        await DataLoader.GetOrLoad(
                () => SeasonLocalCache.GetSeasonsCache(),
                () => SeasonService.GetSeasons(),
                (s) => SeasonLocalCache.SetSeasonsCache(s)
            );
}
