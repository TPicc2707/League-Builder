@page "/footballteamstats/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject IPlayerService PlayerService
@inject IStatsService StatService
@inject ISeasonService SeasonService
@inject IGameService GameService
@inject ITeamService TeamService
@inject ILeagueService LeagueService
@inject IStandingsService StandingsService
@inject IAWSService AWSService
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject IPlayerLocalCacheService PlayerLocalCache
@inject IStatsLocalCacheService StatsLocalCache
@inject ISeasonLocalCacheService SeasonLocalCache
@inject IGameLocalCacheService GameLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject ILeagueLocalCacheService LeagueLocalCache
@inject IStandingsLocalCacheService StandingsLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService

<AuthorizeView Roles="@String.Concat(Roles.ReadStats, ", ", Roles.ReadPlayers, ", ", Roles.ReadTeams, ", ", Roles.ReadSeasons, ", ", Roles.ReadLeagues)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="py-25">
                <MudExpansionPanels>
                    <MudExpansionPanel Expanded="expandSearchPanel" Class="border border-solid" Style="border-color: #000000">
                        <TitleContent>
                            <MudText Typo="Typo.h4" Align="Align.Center" Class="font-bold">
                                <MudStack Row="true" Justify="Justify.Center">
                                    <MudAvatar Size="Size.Medium">
                                        <MudImage Src="@TeamModel.Team.ImageFile" Alt="Team Image"></MudImage>
                                    </MudAvatar>
                                    @SeasonModel.Season.Year @TeamModel.Team.TeamName Stats
                                </MudStack>
                            </MudText>
                        </TitleContent>
                        <ChildContent>
                            <MudStack Justify="Justify.FlexStart" Row="true" Class="pt-6">
                                <MudItem xs="6">
                                    <MudSelect @bind-Value="seasonValue" Placeholder="@seasonPlaceholder" Label="@seasonPlaceholder">
                                        @foreach (var season in SeasonsModel.Seasons)
                                        {
                                            <MudSelectItem Value="season.Year">@season.Year</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="3">

                                </MudItem>
                                <MudItem xs="3" Class="p-3" Style="align-content: center;">
                                    <MudButton Disabled="@(seasonValue <= 0)" OnClick="GetTeamStatsBySeason" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" Style="width: 150px;">Search</MudButton>
                                </MudItem>
                            </MudStack>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Centered="true" Color="Color.Primary" Class="border border-solid p-25" Style="border-color: #000000;">
                <MudTabPanel Text="Passing">
                    <MudItem Class="py-25">
                        <PassingTotalsCard Totals="TeamPassingTotals"
                                                   OnInfoClick="OpenStatDialogAsync" />
                        <PlayerTeamPassingStatsTable Rows="TeamStats.Players" />
                    </MudItem>
                </MudTabPanel>
                <MudTabPanel Text="Rushing">
                    <MudItem Class="py-25">
                        <RushingTotalsCard Totals="TeamRushingTotals"
                                           OnInfoClick="OpenStatDialogAsync" />
                        <PlayerTeamRushingStatsTable Rows="TeamStats.Players" />
                    </MudItem>
                </MudTabPanel>
                <MudTabPanel Text="Receiving">
                    <MudItem Class="py-25">
                        <ReceivingTotalsCard Totals="TeamReceivingTotals"
                                             OnInfoClick="OpenStatDialogAsync" />
                        <PlayerTeamReceivingStatsTable Rows="TeamStats.Players" />
                    </MudItem>
                </MudTabPanel>
                <MudTabPanel Text="Defensive">
                    <MudItem Class="py-25">
                        <DefensiveTotalsCard Totals="TeamDefensiveTotals"
                                             OnInfoClick="OpenStatDialogAsync" />
                        <PlayerTeamDefensiveStatsTable Rows="TeamStats.Players" />
                    </MudItem>
                </MudTabPanel>
                <MudTabPanel Text="Kicking">
                    <MudItem Class="py-25">
                        <KickingTotalsCard Totals="TeamKickingTotals"
                                           OnInfoClick="OpenStatDialogAsync" />
                        <PlayerTeamKickingStatsTable Rows="TeamStats.Players" />
                    </MudItem>
                </MudTabPanel>
            </MudTabs>
        }
        else
        {
            <Loading />
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>


@code {
    [Parameter]
    public string Id { get; set; }
    private bool PageLoad = false;
    private int seasonValue;
    private string seasonPlaceholder = "Season";
    private string imageFile = string.Empty;
    private bool expandSearchPanel = false;
    private IJSObjectReference? _module;

    FootballPassingTotalsModel TeamPassingTotals = new();
    FootballRushingTotalsModel TeamRushingTotals = new();
    FootballReceivingTotalsModel TeamReceivingTotals = new();
    FootballDefensiveTotalsModel TeamDefensiveTotals = new();
    FootballKickingTotalsModel TeamKickingTotals = new();

    private TeamStatRecord TeamStats { get; set; } = new TeamStatRecord();
    private SeasonModel Season { get; set; } = new SeasonModel();
    GetSeasonsResponse SeasonsModel { get; set; }
    GetSeasonByYearResponse SeasonModel { get; set; }
    GetTeamByIdResponse TeamModel { get; set; }
    GetPlayerFootballStatsBySeasonResponse StatsModel { get; set; }
    GetLeagueByIdResponse LeagueModel { get; set; }
    GetStandingsByTeamResponse StandingsModel { get; set; }
    GetPlayersByTeamResponse PlayersByTeam { get; set; }
    GetStandingsByTeamResponse StandingsByTeam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAllAsync();
            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task LoadAllAsync()
    {
        var teamId = Guid.Parse(Id);
        int year = DateTime.Now.Year;
        SeasonsModel = await LoadSeasonsAsync();
        seasonValue = Season.Year;

        TeamModel = await LoadTeamAsync(teamId);
        LeagueModel = await LoadLeagueAsync(TeamModel.Team.LeagueId);

        SeasonModel = await LoadSeasonAsync(year);

        await CreatePlayerStats(teamId, SeasonModel.Season.Id);
        TeamModel.Team.ImageFile = await ImageService.GetTeamImageAsync(LeagueModel.League, TeamModel.Team);
    }

    private async Task GetTeamStatsBySeason()
    {
        PageLoad = false;
        var teamId = Guid.Parse(Id);

        TeamPassingTotals = new();
        TeamRushingTotals = new();
        TeamReceivingTotals = new();
        TeamDefensiveTotals = new();
        TeamKickingTotals = new();

        TeamStats.Players.Clear();
        SeasonModel = await LoadSeasonAsync(seasonValue);
        await CreatePlayerStats(teamId, SeasonModel.Season.Id);
        PageLoad = true;
    }

    private async Task CreatePlayerStats(Guid teamId, Guid seasonId)
    {
        await LoadPlayersAndImage(teamId);
        var teamGames = StandingsByTeam.Standings.FirstOrDefault(s => s.SeasonId == Season.Id).StandingsDetail.GamesPlayed;
        TeamPassingTotals = new();
        TeamRushingTotals = new();
        TeamReceivingTotals = new();
        TeamDefensiveTotals = new();
        TeamKickingTotals = new();

        foreach (var player in PlayersByTeam.Players)
        {
            var playerPassingTotals = new FootballPassingTotalsModel();
            var playerRushingTotals = new FootballRushingTotalsModel();
            var playerReceivingTotals = new FootballReceivingTotalsModel();
            var playerDefensiveTotals = new FootballDefensiveTotalsModel();
            var playerKickingTotals = new FootballKickingTotalsModel();
            int gamesPlayed = 0;

            StatsModel = await LoadPlayerStatsBySeasonAsync(player.Id, seasonId);

            AccumulatePlayerStats(StatsModel.FootballStats, playerPassingTotals,
                                  playerRushingTotals, playerReceivingTotals, playerDefensiveTotals,
                                  playerKickingTotals, ref gamesPlayed);
            FinalizePlayerStats(playerPassingTotals, playerRushingTotals,
                                playerReceivingTotals, playerKickingTotals, gamesPlayed);

            AccumulateTeamStats(StatsModel.FootballStats);

            BuildRow(player, playerPassingTotals, playerRushingTotals,
                     playerReceivingTotals, playerDefensiveTotals,
                     playerKickingTotals, gamesPlayed);


        }

        FinalizeTeamStats(teamGames);
    }

    private async Task LoadPlayersAndImage(Guid teamId)
    {
        StandingsByTeam = await LoadTeamStandingsAsync(teamId);
        PlayersByTeam = await LoadPlayersByTeamAsync(teamId);
        await GetImageAsync(PlayersByTeam.Players);
    }

    private void AccumulatePlayerStats(IEnumerable<FootballStatsModel> stats, FootballPassingTotalsModel playerPassing, 
                                             FootballRushingTotalsModel playerRushing, FootballReceivingTotalsModel playerReceiving, 
                                             FootballDefensiveTotalsModel playerDefensive,FootballKickingTotalsModel playerKicking, ref int gamesPlayed)
    {
        foreach(var s in stats)
        {
            //Passing
            playerPassing.PassingCompletions += s.OffensiveStats.PassingCompletions;
            playerPassing.PassingAttempts += s.OffensiveStats.PassingAttempts;
            playerPassing.PassingYards += s.OffensiveStats.PassingYards;
            playerPassing.PassingTouchdowns += s.OffensiveStats.PassingTouchdowns;
            playerPassing.PassingInterceptions += s.OffensiveStats.PassingInterceptions;
            playerPassing.Sacks += s.OffensiveStats.Sacks;

            if (playerPassing.LongestPassingPlay <= s.OffensiveStats.LongestPassingPlay)
                playerPassing.LongestPassingPlay = s.OffensiveStats.LongestPassingPlay;

            //Rushing
            playerRushing.RushingYards += s.OffensiveStats.RushingYards;
            playerRushing.RushingAttempts += s.OffensiveStats.RushingAttempts;
            playerRushing.RushingTouchdowns += s.OffensiveStats.RushingTouchdowns;
            playerRushing.RushingFumbles += s.OffensiveStats.RushingFumbles;
            playerRushing.RushingFumblesLost += s.OffensiveStats.RushingFumblesLost;

            if (playerRushing.LongestRushingPlay <= s.OffensiveStats.LongestRushingPlay)
                playerRushing.LongestRushingPlay = s.OffensiveStats.LongestRushingPlay;


            //Recieving
            playerReceiving.Receptions += s.OffensiveStats.Receptions;
            playerReceiving.Targets += s.OffensiveStats.Targets;
            playerReceiving.ReceivingYards += s.OffensiveStats.ReceivingYards;
            playerReceiving.ReceivingTouchdowns += s.OffensiveStats.ReceivingTouchdowns;
            playerReceiving.ReceivingFumbles += s.OffensiveStats.ReceivingFumbles;
            playerReceiving.ReceivingFumblesLost += s.OffensiveStats.ReceivingFumblesLost;
            playerReceiving.YardsAfterCatch += s.OffensiveStats.YardsAfterCatch;

            //Defensive
            playerDefensive.Tackles += s.DefensiveStats.Tackles;
            playerDefensive.DefensiveSacks += s.DefensiveStats.Sacks;
            playerDefensive.TacklesForLoss += s.DefensiveStats.TacklesForLoss;
            playerDefensive.ForcedFumbles += s.DefensiveStats.ForcedFumbles;
            playerDefensive.RecoveredFumbles += s.DefensiveStats.RecoveredFumbles;
            playerDefensive.DefensiveInterceptions += s.DefensiveStats.DefensiveInterceptions;
            playerDefensive.PassesDefended += s.DefensiveStats.PassesDefended;
            playerDefensive.DefensiveInterceptionYards += s.DefensiveStats.DefensiveInterceptionYards;
            playerDefensive.DefensiveTouchdowns += s.DefensiveStats.DefensiveTouchdowns;

            if (playerDefensive.LongestDefensiveInterception <= s.DefensiveStats.LongestDefensiveInterceptionPlay)
                playerDefensive.LongestDefensiveInterception = s.DefensiveStats.LongestDefensiveInterceptionPlay;

            //Kicking
            playerKicking.FieldGoalsMade += s.KickingStats.FieldGoalsMade;
            playerKicking.FieldGoalsAttempted += s.KickingStats.FieldGoalsAttempted;
            playerKicking.ExtraPointsMade += s.KickingStats.ExtraPointsMade;
            playerKicking.ExtraPointsAttempted += s.KickingStats.ExtraPointsAttempted;
            playerKicking.Points += s.KickingStats.Points;
            playerKicking.Punts += s.KickingStats.Punts;
            playerKicking.PuntingYards += s.KickingStats.PuntingYards;

            if (playerKicking.LongestPunt <= s.KickingStats.LongestPunt)
                playerKicking.LongestPunt = s.KickingStats.LongestPunt;

            if (playerKicking.LongestKick <= s.KickingStats.LongestKick)
                playerKicking.LongestKick = s.KickingStats.LongestKick;


            gamesPlayed += playerPassing.PassingAttempts > 0 || playerRushing.RushingAttempts > 0 || playerReceiving.Targets > 0 || playerDefensive.Tackles > 0 || playerKicking.ExtraPointsAttempted > 0 || playerKicking.FieldGoalsAttempted > 0 || playerKicking.Punts > 0 ? 1 : 0;
        }
    }

    private void FinalizePlayerStats(FootballPassingTotalsModel playerPassing,
                                           FootballRushingTotalsModel playerRushing, FootballReceivingTotalsModel playerReceiving,
                                           FootballKickingTotalsModel playerKicking, int gamesPlayed)
    {
        playerPassing.PassingCompletionPercentage = SafePct(playerPassing.PassingCompletions, playerPassing.PassingAttempts);
        playerPassing.PassingYardsPerPlay = SafeAvg(playerPassing.PassingYards, playerPassing.PassingCompletions);
        playerRushing.RushingYardsPerPlay = SafeAvg(playerRushing.RushingYards, playerRushing.RushingAttempts);
        playerReceiving.ReceivingYardsPerPlay = SafeAvg(playerReceiving.ReceivingYards, playerReceiving.Receptions);

        playerPassing.PassingYardsPerGame = SafeAvg(playerPassing.PassingYards, gamesPlayed);
        playerRushing.RushingYardsPerGame = SafeAvg(playerRushing.RushingYards, gamesPlayed);
        playerReceiving.ReceivingYardsPerGame = SafeAvg(playerReceiving.ReceivingYards, gamesPlayed);

        playerKicking.FieldGoalPercentage = SafePct(playerKicking.FieldGoalsMade, playerKicking.FieldGoalsAttempted);
        playerKicking.ExtraPointPercentage = SafePct(playerKicking.ExtraPointsMade, playerKicking.ExtraPointsAttempted);

    }

    private void BuildRow(PlayerModel player, FootballPassingTotalsModel playerPassing,
                          FootballRushingTotalsModel playerRushing, FootballReceivingTotalsModel playerReceiving,
                          FootballDefensiveTotalsModel playerDefensive, FootballKickingTotalsModel playerKicking, int gamesPlayed)
    {
        var offensiveStats = new FootballOffensiveStatsModel(playerPassing.PassingCompletions, playerPassing.PassingAttempts, playerPassing.PassingCompletionPercentage,
                                                    playerPassing.PassingYards, playerPassing.PassingYardsPerPlay, playerPassing.LongestPassingPlay, playerPassing.PassingTouchdowns,
                                                    playerPassing.PassingInterceptions, playerPassing.Sacks, 0, playerRushing.RushingAttempts, playerRushing.RushingYards, playerRushing.RushingYardsPerPlay,
                                                    playerRushing.LongestRushingPlay, playerRushing.RushingTouchdowns, playerRushing.RushingFumbles, playerRushing.RushingFumblesLost,
                                                    playerReceiving.Receptions, playerReceiving.Targets, playerReceiving.ReceivingYards, playerReceiving.ReceivingYardsPerPlay,
                                                    playerReceiving.ReceivingTouchdowns, playerReceiving.ReceivingFumbles, playerReceiving.ReceivingFumblesLost, playerReceiving.YardsAfterCatch);

        var defensiveStats = new FootballDefensiveStatsModel(playerDefensive.Tackles, playerDefensive.DefensiveSacks, playerDefensive.TacklesForLoss, playerDefensive.PassesDefended,
                                                             playerDefensive.DefensiveInterceptions, playerDefensive.DefensiveInterceptionYards, playerDefensive.LongestDefensiveInterception,
                                                             playerDefensive.DefensiveTouchdowns, playerDefensive.ForcedFumbles, playerDefensive.RecoveredFumbles);

        var kickingStats = new FootballKickingStatsModel(playerKicking.FieldGoalsMade, playerKicking.FieldGoalsAttempted, playerKicking.FieldGoalPercentage,
                                                         playerKicking.ExtraPointsMade, playerKicking.ExtraPointsAttempted, playerKicking.ExtraPointPercentage,
                                                         playerKicking.LongestKick, playerKicking.Points, playerKicking.Punts, playerKicking.PuntingYards,
                                                         playerKicking.LongestPunt);

        TeamStats.Players.Add(new PlayerStatsRecord(player, new FootballSeasonStats(offensiveStats, defensiveStats, kickingStats, gamesPlayed), 
                                                    playerPassing.PassingYardsPerGame, playerRushing.RushingYardsPerGame, playerReceiving.ReceivingYardsPerGame));
    }

    private void AccumulateTeamStats(IEnumerable<FootballStatsModel> stats)
    {
        foreach(var s in stats)
        {
            //Passing
            TeamPassingTotals.PassingCompletions += s.OffensiveStats.PassingCompletions;
            TeamPassingTotals.PassingAttempts += s.OffensiveStats.PassingAttempts;
            TeamPassingTotals.PassingYards += s.OffensiveStats.PassingYards;
            TeamPassingTotals.PassingTouchdowns += s.OffensiveStats.PassingTouchdowns;
            TeamPassingTotals.PassingInterceptions += s.OffensiveStats.PassingInterceptions;
            TeamPassingTotals.Sacks += s.OffensiveStats.Sacks;

            if (TeamPassingTotals.LongestPassingPlay <= s.OffensiveStats.LongestPassingPlay)
                TeamPassingTotals.LongestPassingPlay = s.OffensiveStats.LongestPassingPlay;

            //Rushing
            TeamRushingTotals.RushingYards += s.OffensiveStats.RushingYards;
            TeamRushingTotals.RushingAttempts += s.OffensiveStats.RushingAttempts;
            TeamRushingTotals.RushingTouchdowns += s.OffensiveStats.RushingTouchdowns;
            TeamRushingTotals.RushingFumbles += s.OffensiveStats.RushingFumbles;
            TeamRushingTotals.RushingFumblesLost += s.OffensiveStats.RushingFumblesLost;

            if (TeamRushingTotals.LongestRushingPlay <= s.OffensiveStats.LongestRushingPlay)
                TeamRushingTotals.LongestRushingPlay = s.OffensiveStats.LongestRushingPlay;

            //Recieving
            TeamReceivingTotals.Receptions += s.OffensiveStats.Receptions;
            TeamReceivingTotals.Targets += s.OffensiveStats.Targets;
            TeamReceivingTotals.ReceivingYards += s.OffensiveStats.ReceivingYards;
            TeamReceivingTotals.ReceivingTouchdowns += s.OffensiveStats.ReceivingTouchdowns;
            TeamReceivingTotals.ReceivingFumbles += s.OffensiveStats.ReceivingFumbles;
            TeamReceivingTotals.ReceivingFumblesLost += s.OffensiveStats.ReceivingFumblesLost;
            TeamReceivingTotals.YardsAfterCatch += s.OffensiveStats.YardsAfterCatch;

            //Defensive
            TeamDefensiveTotals.Tackles += s.DefensiveStats.Tackles;
            TeamDefensiveTotals.DefensiveSacks += s.DefensiveStats.Sacks;
            TeamDefensiveTotals.TacklesForLoss += s.DefensiveStats.TacklesForLoss;
            TeamDefensiveTotals.ForcedFumbles += s.DefensiveStats.ForcedFumbles;
            TeamDefensiveTotals.RecoveredFumbles += s.DefensiveStats.RecoveredFumbles;
            TeamDefensiveTotals.DefensiveInterceptions += s.DefensiveStats.DefensiveInterceptions;
            TeamDefensiveTotals.PassesDefended += s.DefensiveStats.PassesDefended;
            TeamDefensiveTotals.DefensiveInterceptionYards += s.DefensiveStats.DefensiveInterceptionYards;
            TeamDefensiveTotals.DefensiveTouchdowns += s.DefensiveStats.DefensiveTouchdowns;

            if (TeamDefensiveTotals.LongestDefensiveInterception <= s.DefensiveStats.LongestDefensiveInterceptionPlay)
                TeamDefensiveTotals.LongestDefensiveInterception = s.DefensiveStats.LongestDefensiveInterceptionPlay;

            //Kicking
            TeamKickingTotals.FieldGoalsMade += s.KickingStats.FieldGoalsMade;
            TeamKickingTotals.FieldGoalsAttempted += s.KickingStats.FieldGoalsAttempted;
            TeamKickingTotals.ExtraPointsMade += s.KickingStats.ExtraPointsMade;
            TeamKickingTotals.ExtraPointsAttempted += s.KickingStats.ExtraPointsAttempted;
            TeamKickingTotals.Points += s.KickingStats.Points;
            TeamKickingTotals.Punts += s.KickingStats.Punts;
            TeamKickingTotals.PuntingYards += s.KickingStats.PuntingYards;

            if (TeamKickingTotals.LongestPunt <= s.KickingStats.LongestPunt)
                TeamKickingTotals.LongestPunt = s.KickingStats.LongestPunt;

            if (TeamKickingTotals.LongestKick <= s.KickingStats.LongestKick)
                TeamKickingTotals.LongestKick = s.KickingStats.LongestKick;
        }
    }

    private void FinalizeTeamStats(int teamGames)
    {
        TeamPassingTotals.PassingCompletionPercentage = SafePct(TeamPassingTotals.PassingCompletions, TeamPassingTotals.PassingAttempts);
        TeamPassingTotals.PassingYardsPerGame = SafeAvg(TeamPassingTotals.PassingYards, teamGames);
        TeamPassingTotals.PassingYardsPerPlay = SafeAvg(TeamPassingTotals.PassingYards, TeamPassingTotals.PassingCompletions);
        TeamRushingTotals.RushingYardsPerGame = SafeAvg(TeamRushingTotals.RushingYards, teamGames);
        TeamRushingTotals.RushingYardsPerPlay = SafeAvg(TeamRushingTotals.RushingYards, TeamRushingTotals.RushingAttempts);
        TeamReceivingTotals.ReceivingYardsPerGame = SafeAvg(TeamReceivingTotals.ReceivingYards, teamGames);
        TeamReceivingTotals.ReceivingYardsPerPlay = SafeAvg(TeamReceivingTotals.ReceivingYards, TeamReceivingTotals.Receptions);
        TeamKickingTotals.FieldGoalPercentage = SafePct(TeamKickingTotals.FieldGoalsMade, TeamKickingTotals.FieldGoalsAttempted);
        TeamKickingTotals.ExtraPointPercentage = SafePct(TeamKickingTotals.ExtraPointsMade, TeamKickingTotals.ExtraPointsAttempted);

    }


    private async Task GetImageAsync(IEnumerable<PlayerModel> players)
    {
        foreach (var player in players)
            player.Image = await ImageService.GetPlayerImageAsync(LeagueModel.League, TeamModel.Team, player);
    }

    private Task OpenStatDialogAsync(string message)
    {
        var parameters = new DialogParameters<StatInfoMessageBox> { { x => x.Message, message } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        return DialogService.ShowAsync<StatInfoMessageBox>("Stat Info", parameters, options);
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private decimal SafeAvg(int numerator, int denominator) =>
        denominator == 0 ? 0 : (decimal)numerator / denominator;

    private decimal SafePct(int made, int attempted) =>
        attempted == 0 ? 0 : (decimal)made / attempted * 100;


    private Task<GetSeasonsResponse> LoadSeasonsAsync() =>
        DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonsCache(),
            () => SeasonService.GetSeasons(),
            (s) => SeasonLocalCache.SetSeasonsCache(s)
    );

    private Task<GetSeasonByYearResponse> LoadSeasonAsync(int year) =>
        DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonByYearCache(year),
            () => SeasonService.GetSeasonByYear(year),
            (s) => SeasonLocalCache.SetSeasonByYearCache(year, s)
    );

    private Task<GetTeamByIdResponse> LoadTeamAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(id.ToString()),
            () => TeamService.GetTeamById(id),
            (t) => TeamLocalCache.SetTeamByIdCache(id.ToString(), t)
    );

    private Task<GetLeagueByIdResponse> LoadLeagueAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeagueByIdCache(id.ToString()),
            () => LeagueService.GetLeague(id),
            (l) => LeagueLocalCache.SetLeagueByIdCache(id.ToString(), l)
    );

    private Task<GetPlayersByTeamResponse> LoadPlayersByTeamAsync(Guid teamId) =>
        DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayersByTeamCache(teamId.ToString()),
            () => PlayerService.GetPlayersByTeam(teamId),
            (p) => PlayerLocalCache.SetPlayersByTeamCache(teamId.ToString(), p)
    );

    private Task<GetPlayerFootballStatsBySeasonResponse> LoadPlayerStatsBySeasonAsync(Guid id, Guid seasonId) =>
        DataLoader.GetOrLoad(
            () => StatsLocalCache.GetPlayerFootballStatsBySeasonCache(id.ToString(), seasonId.ToString()),
            () => StatService.GetPlayerFootballStatsBySeason(id, seasonId),
            (s) => StatsLocalCache.SetPlayerFootballStatsBySeasonCache(id.ToString(), seasonId.ToString(), s)
    );

    private Task<GetStandingsByTeamResponse> LoadTeamStandingsAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => StandingsLocalCache.GetStandingsByTeamCache(id.ToString()),
            () => StandingsService.GetStandingsByTeam(id),
            (s) => StandingsLocalCache.SetStandingsByTeamCache(id.ToString(), s)
    );

}
