@page "/teamgames/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject IGameService GamesService
@inject ISeasonService SeasonService
@inject ILeagueService LeagueService
@inject ITeamService TeamService
@inject IDialogService DialogService
@inject IAWSService AWSService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISeasonLocalCacheService SeasonLocalCache
@inject IGameLocalCacheService GameLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject ILeagueLocalCacheService LeagueLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService
@inject AuthenticationStateProvider AuthenticationStateProvider

<AuthorizeView Roles="@String.Concat(Roles.ReadGames, ", ", Roles.ReadSeasons)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="py-25">
                <MudExpansionPanels>
                    <MudExpansionPanel Expanded="expandSearchPanel" Class="border border-solid" Style="border-color: #000000">
                        <TitleContent>
                            <MudText Typo="Typo.h4" Align="Align.Center" Class="font-bold">
                                <MudStack Row="true" Justify="Justify.Center">
                                    <MudAvatar Size="Size.Medium">
                                        <MudImage Src="@TeamModel.Team.ImageFile" Alt="Team Image"></MudImage>
                                    </MudAvatar>
                                    @TeamModel.Team.TeamName                                    
                                </MudStack>
                                </MudText>
                        </TitleContent>
                        <ChildContent>
                            <MudStack Justify="Justify.FlexStart" Row="true" Class="pt-6">
                                <MudItem xs="6">
                                    <MudSelect @bind-Value="seasonValue" Placeholder="@placeholder" Label="@placeholder">
                                        @foreach (var season in SeasonsModel.Seasons)
                                        {
                                            <MudSelectItem Value="season.Year">@season.Year</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="3">

                                </MudItem>
                                <MudItem xs="3" Class="p-3" Style="align-content: center;">
                                    <MudButton Disabled="@(seasonValue <= 0)" OnClick="GetSeasonGames" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" Style="width: 200px;">Search</MudButton>
                                </MudItem>
                            </MudStack>

                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            <MudItem>
                <MudPaper Elevation="2" Class="border border-solid p-25" Style="border-color: #000000;">
                    <MudItem>
                        <MudTable Items="@Games.OrderBy(x => x.GameDetail.StartTime)" Hover="true" SortLabel="Sort By" Class="border border-solid" Style="border-color: #000000">
                            <ColGroup>
                                <col />
                                <col />
                                <col />
                            </ColGroup>
                            <HeaderContent>
                                <MudTh Class="mud-theme-primary font-bold">Date</MudTh>
                                <MudTh Class="mud-theme-primary font-bold">Time</MudTh>
                                <MudTh Class="mud-theme-primary font-bold">Opponent</MudTh>
                                <MudTh Class="mud-theme-primary font-bold">Outcome</MudTh>
                                <MudTh Class="mud-theme-primary font-bold">Score</MudTh>
                                <MudTh Class="mud-theme-primary font-bold">Record</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Date">
                                    @context.GameDetail.StartTime.ToString("ddd, MMM d")
                                </MudTd>
                                <MudTd DataLabel="Time">
                                    @context.GameDetail.StartTime.ToString("hh:mm tt")
                                </MudTd>
                                <MudTd DataLabel="Opponent">
                                    @OpponentCell(context)
                                </MudTd>
                                <MudTd DataLabel="Outcome">
                                   @OutcomeCell(context)
                                </MudTd>
                                <MudTd DataLabel="Score">
                                   @ScoreCell(context)
                                </MudTd>
                                <MudTd DataLabel="Record">
                                    @RecordCell(context)
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager />
                            </PagerContent>
                        </MudTable>

                    </MudItem>

                </MudPaper>

            </MudItem>
        }
        else
        {
            <Loading />
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>


@code {
    [Parameter]
    public string Id { get; set; }
    private bool PageLoad = false;
    private Justify _justify = Justify.SpaceEvenly;
    private SeasonModel Season;
    private string placeholder = "Season";
    private string awayPlaceholder = "@";
    private string homePlaceholder = "vs";
    private int seasonValue;
    private bool expandSearchPanel = false;
    private int teamSeasonWins = 0;
    private int teamSeasonLosses = 0;
    private string editSport = string.Empty;
    private IJSObjectReference? _module;
    private GetSeasonsResponse SeasonsModel { get; set; }
    private GetSeasonByYearResponse SeasonModel { get; set; }
    private GetGamesByTeamResponse Model { get; set; }
    private GetTeamByIdResponse TeamModel { get; set; }
    private GetLeagueByIdResponse LeagueModel { get; set; }
    private IEnumerable<GameModel> Games { get; set; }
    private bool CanUpdateGames;


    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            CanUpdateGames = user.IsInRole(Roles.UpdateGames);

            await LoadAllAsync();
            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task LoadAllAsync()
    {
        var teamId = Guid.Parse(Id);
        SeasonsModel = await LoadSeasonsAsync();
        Season = SeasonsModel.Seasons.First();
        Model = await LoadGamesAsync(teamId);
        Games = Model.Games.Where(x => x.GameDetail.StartTime.Year == Season.Year);
        TeamModel = await LoadTeamAsync(teamId);
        LeagueModel = await LoadLeagueAsync(TeamModel.Team.LeagueId);
        editSport = $"edit{LeagueModel.League.Sport}gamestats";
        seasonValue = Season.Year;
        await GetImageAsync();
        TeamModel.Team.ImageFile = await ImageService.GetTeamImageAsync(LeagueModel.League, TeamModel.Team);
    }

    private async Task GetSeasonGames()
    {
        try
        {
            PageLoad = false;
            teamSeasonWins = 0;
            teamSeasonLosses = 0;
            SeasonModel = await LoadSeasonAsync(seasonValue);
            Season = SeasonModel.Season;
            Games = Model.Games.Where(x => x.GameDetail.StartTime.Year == Season.Year);
            await GetImageAsync();
            StateHasChanged();
            PageLoad = true;

        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task GetImageAsync()
    {
        foreach (var game in Games.OrderBy(x => x.GameDetail.StartTime))
        {
            bool isAway = game.AwayTeam.Id == TeamModel.Team.Id;
            var opponentId = isAway ? game.HomeTeam.Id : game.AwayTeam.Id;

            if (game.GameStatus == GameStatus.Completed)
                UpdateSeasonRecord(game, isAway);

            var opponent = await GetOpponentAsync(opponentId);

            var opponentImage = await ImageService.GetTeamImageAsync(LeagueModel.League, opponent.Team);

            if (isAway)
                game.HomeTeamImage = opponentImage;
            else
                game.AwayTeamImage = opponentImage;

            game.TeamSeasonWins = teamSeasonWins;
            game.TeamSeasonLosses = teamSeasonLosses;
        }

    }

    private void UpdateSeasonRecord(GameModel game, bool isAway)
    {
        int teamScore = isAway ? game.GameDetail.AwayTeamScore : game.GameDetail.HomeTeamScore;
        int oppScore = isAway ? game.GameDetail.HomeTeamScore : game.GameDetail.AwayTeamScore;

        if (teamScore > oppScore)
            teamSeasonWins++;
        else
            teamSeasonLosses++;
    }

    private async Task<GetTeamByIdResponse> GetOpponentAsync(Guid opponentId)
    {
        var opponent = await LoadTeamAsync(opponentId);

        return opponent;
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private Task<GetSeasonsResponse> LoadSeasonsAsync() =>
       DataLoader.GetOrLoad(
           () => SeasonLocalCache.GetSeasonsCache(),
           () => SeasonService.GetSeasons(),
           (s) => SeasonLocalCache.SetSeasonsCache(s)
   );

    private Task<GetSeasonByYearResponse> LoadSeasonAsync(int year) =>
     DataLoader.GetOrLoad(
         () => SeasonLocalCache.GetSeasonByYearCache(year),
         () => SeasonService.GetSeasonByYear(year),
         (s) => SeasonLocalCache.SetSeasonByYearCache(year, s)
     );


    private Task<GetGamesByTeamResponse> LoadGamesAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => GameLocalCache.GetGamesByTeamCache(id.ToString()),
            () => GamesService.GetGamesByTeam(id),
            (g) => GameLocalCache.SetGamesByTeamCache(id.ToString(), g)
    );

    private Task<GetTeamByIdResponse> LoadTeamAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(id.ToString()),
            () => TeamService.GetTeamById(id),
            (t) => TeamLocalCache.SetTeamByIdCache(id.ToString(), t)
    );

    private Task<GetLeagueByIdResponse> LoadLeagueAsync(Guid leagueId) =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeagueByIdCache(leagueId.ToString()),
            () => LeagueService.GetLeague(leagueId),
            (l) => LeagueLocalCache.SetLeagueByIdCache(leagueId.ToString(), l)
    );

    private record OpponentView(Guid Id, string TeamName, string Image);

    private RenderFragment OpponentCell(GameModel game) =>@<MudStack Row="true" Spacing="2">
        @{
            bool isAway = game.AwayTeam.Id == TeamModel.Team.Id;
            var opponent = isAway ? new OpponentView(game.HomeTeam.Id, game.HomeTeam.TeamName, game.HomeTeamImage) : new OpponentView(game.AwayTeam.Id, game.AwayTeam.TeamName, game.AwayTeamImage);
        }
        <MudAvatar Size="Size.Small">
            <MudImage Src="@opponent.Image" Alt="Team Image" />
        </MudAvatar>
        @if(CanUpdateGames)
        {
            <MudLink Color="Color.Tertiary" Href="@($"/{editSport}{game.Id}")">
                @opponent.TeamName
            </MudLink>
        }
        else
        {
            @opponent.TeamName
        }
    </MudStack>
    ;

    private RenderFragment OutcomeCell(GameModel game) =>@<div>
        @if(game.GameStatus == GameStatus.Completed)
        {
            bool isAway = game.AwayTeam.Id == TeamModel.Team.Id;
            int teamScore = isAway ? game.GameDetail.AwayTeamScore : game.GameDetail.HomeTeamScore;
            int oppScore = isAway ? game.GameDetail.HomeTeamScore : game.GameDetail.AwayTeamScore;

            bool win = teamScore > oppScore;

            <MudText Color="@(win ? Color.Success : Color.Error)" Class="ml-4">
                @(win ? "W" : "L")
            </MudText>
        }
    </div>
    ;

    private RenderFragment ScoreCell(GameModel game) =>@<div>
        @if(game.GameStatus == GameStatus.Completed)
        {
            <MudText Class="ml-2">
                @game.GameDetail.AwayTeamScore - @game.GameDetail.HomeTeamScore
            </MudText>
        }
    </div>;

    private RenderFragment RecordCell(GameModel game) =>@<div>
        @if(game.GameStatus == GameStatus.Completed)
        {
            <MudText Class="ml-2">
                @game.TeamSeasonWins - @game.TeamSeasonLosses
            </MudText>
        }
    </div>;
}
