@page "/basketballteamstats/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject IPlayerService PlayerService
@inject IStatsService StatService
@inject ISeasonService SeasonService
@inject IGameService GameService
@inject ITeamService TeamService
@inject ILeagueService LeagueService
@inject IStandingsService StandingsService
@inject IAWSService AWSService
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject IPlayerLocalCacheService PlayerLocalCache
@inject IStatsLocalCacheService StatsLocalCache
@inject ISeasonLocalCacheService SeasonLocalCache
@inject IGameLocalCacheService GameLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject ILeagueLocalCacheService LeagueLocalCache
@inject IStandingsLocalCacheService StandingsLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService

<AuthorizeView Roles="@String.Concat(Roles.ReadStats, ", ", Roles.ReadSeasons, ", ", Roles.ReadGames, ", ", Roles.ReadTeams, ", ", Roles.ReadPlayers)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="py-25">
                <MudExpansionPanels>
                    <MudExpansionPanel Expanded="expandSearchPanel" Class="border border-solid" Style="border-color: #000000">
                        <TitleContent>
                            <MudText Typo="Typo.h4" Align="Align.Center" Class="font-bold">
                                <MudStack Row="true" Justify="Justify.Center">
                                    <MudAvatar Size="Size.Medium">
                                        <MudImage Src="@TeamModel.Team.ImageFile" Alt="Team Image"></MudImage>
                                    </MudAvatar>
                                    @SeasonModel.Season.Year @TeamModel.Team.TeamName Stats
                                </MudStack>
                            </MudText>
                        </TitleContent>
                        <ChildContent>
                            <MudStack Justify="Justify.FlexStart" Row="true" Class="pt-6">
                                <MudItem xs="6">
                                    <MudSelect @bind-Value="seasonValue" Placeholder="@seasonPlaceholder" Label="@seasonPlaceholder">
                                        @foreach (var season in SeasonsModel.Seasons)
                                        {
                                            <MudSelectItem Value="season.Year">@season.Year</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="3">

                                </MudItem>
                                <MudItem xs="3" Class="p-3" Style="align-content: center;">
                                    <MudButton Disabled="@(seasonValue <= 0 ? true : false)" OnClick="GetTeamStatsBySeason" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" Style="width: 150px;">Search</MudButton>
                                </MudItem>
                            </MudStack>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Centered="true" Color="Color.Primary" Class="border border-solid p-25" Style="border-color: #000000;">
                <MudTabPanel Text="Stats">
                    <MudItem Class="py-25">
                        <BasketballStatsTotalsCard Totals="TeamTotals"
                                                   Index="1"
                                                   OnInfoClick="OpenStatDialogAsync" />
                    </MudItem>
                    <MudItem Class="mt-50">
                        <BasketballStatsTotalsCard Totals="TeamTotals"
                                                   Index="2"
                                                   OnInfoClick="OpenStatDialogAsync" />
                    </MudItem>
                    <MudItem Class="padtop-20">
                        <PlayerTeamBasketballStatsTable Rows="TeamStats.Players" />
                    </MudItem>
                </MudTabPanel>
            </MudTabs>
        }
        else
        {
            <Loading />
        }


    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>


@code {
    [Parameter]
    public string Id { get; set; }
    private bool PageLoad = false;
    private int seasonValue;
    private string seasonPlaceholder = "Season";
    private string imageFile = string.Empty;
    private bool expandSearchPanel = false;
    private IJSObjectReference? _module;

    BasketballTotalsModel TeamTotals = new();

    private TeamStatRecord TeamStats { get; set; } = new TeamStatRecord();
    private SeasonModel Season { get; set; } = new SeasonModel();
    GetSeasonsResponse SeasonsModel { get; set; }
    GetSeasonByYearResponse SeasonModel { get; set; }
    GetTeamByIdResponse TeamModel { get; set; }
    GetPlayerBasketballStatsBySeasonResponse StatsModel { get; set; }
    GetLeagueByIdResponse LeagueModel { get; set; }
    GetPlayersByTeamResponse PlayersByTeam { get; set; }
    GetStandingsByTeamResponse StandingsByTeam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAllAsync();
            PageLoad = true;
        }
        catch (Exception ex)
        {
            if (KeycloakTokenService.ShouldForceLogout())
            {
                _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
                await _module.InvokeVoidAsync("logout");
            }
            ErrorState.Message = ex.Message;
            NavManager.NavigateTo("/error");
        }
    }

    private async Task LoadAllAsync()
    {
        var teamId = Guid.Parse(Id);
        int year = DateTime.Now.Year;
        SeasonsModel = await LoadSeasonsAsync();
        Season = SeasonsModel.Seasons.FirstOrDefault(x => x.Year == year);
        seasonValue = Season.Year;
        TeamModel = await LoadTeamAsync(teamId);
        LeagueModel = await LoadLeagueAsync(TeamModel.Team.LeagueId);
        SeasonModel = await LoadSeasonAsync(year);
        await CreatePlayerStats(teamId, SeasonModel.Season.Id);
        TeamModel.Team.ImageFile = await ImageService.GetTeamImageAsync(LeagueModel.League, TeamModel.Team);
    }

    private async Task GetTeamStatsBySeason()
    {
        PageLoad = false;
        var teamId = Guid.Parse(Id);
        TeamTotals = new();
        TeamStats.Players.Clear();
        SeasonModel = await LoadSeasonAsync(seasonValue);
        await CreatePlayerStats(teamId, SeasonModel.Season.Id);
        PageLoad = true;
    }

    private async Task CreatePlayerStats(Guid teamId, Guid seasonId)
    {
        StandingsByTeam = await LoadTeamStandingsAsync(teamId);
        var teamGames = StandingsByTeam.Standings.FirstOrDefault(s => s.SeasonId == Season.Id).StandingsDetail.GamesPlayed;
        PlayersByTeam = await LoadPlayersByTeamAsync(teamId);
        await GetImageAsync(PlayersByTeam.Players);
        foreach (var player in PlayersByTeam.Players)
        {
            var playerTotalStats = new BasketballTotalsModel();
            var playerStats = new BasketballPlayerStats();
            int gamesPlayed = 0;
            StatsModel = await LoadPlayerStatsBySeasonAsync(player.Id, seasonId);

            AccumulatePlayerStats(StatsModel.BasketballStats, playerTotalStats, gamesPlayed);
            FinalizePlayerStats(playerTotalStats, playerStats, gamesPlayed);

            AccumulateTeamStats(StatsModel.BasketballStats);

            BuildRows(player, playerStats, playerTotalStats.Starts, gamesPlayed);
        }

        FinalizeTeamStats(teamGames);

    }

    private void BuildRows(PlayerModel player, BasketballPlayerStats playerStats, int gamesStarted, int gamesPlayed)
    {
        var playerSeasonStats = new BasketballSeasonStats(playerStats, gamesStarted, gamesPlayed);
        var playerStat = new PlayerStatsRecord(player, playerSeasonStats);
        TeamStats.Players.Add(playerStat);
    }

    private void AccumulatePlayerStats(IEnumerable<BasketballStatsModel> stats, BasketballTotalsModel playerStats, int gamesPlayed)
    {
        foreach(var s in stats)
        {
            playerStats.Points += s.Stats.Points;
            playerStats.FieldGoalsMade += s.Stats.FieldGoalsMade;
            playerStats.FieldGoalsAttempted += s.Stats.FieldGoalsAttempted;
            playerStats.ThreePointersMade += s.Stats.ThreePointersMade;
            playerStats.ThreePointersAttempted += s.Stats.ThreePointersAttempted;
            playerStats.FreeThrowsMade += s.Stats.FreeThrowsMade;
            playerStats.FreeThrowsAttempted += s.Stats.FreeThrowsAttempted;
            playerStats.Rebounds += s.Stats.Rebounds;
            playerStats.Assists += s.Stats.Assists;
            playerStats.Steals += s.Stats.Steals;
            playerStats.Blocks += s.Stats.Blocks;
            playerStats.Turnovers += s.Stats.Turnovers;
            playerStats.Fouls += s.Stats.Fouls;
            playerStats.Minutes += s.Stats.Minutes;
            gamesPlayed += s.Stats.Minutes > 0 ? 1 : 0;
            playerStats.Starts += s.Stats.Start ? 1 : 0;
        }
    }

    private void AccumulateTeamStats(IEnumerable<BasketballStatsModel> stats)
    {
        foreach(var s in stats)
        {
            TeamTotals.Points += s.Stats.Points;
            TeamTotals.FieldGoalsMade += s.Stats.FieldGoalsMade;
            TeamTotals.FieldGoalsAttempted += s.Stats.FieldGoalsAttempted;
            TeamTotals.ThreePointersMade += s.Stats.ThreePointersMade;
            TeamTotals.ThreePointersAttempted += s.Stats.ThreePointersAttempted;
            TeamTotals.FreeThrowsMade += s.Stats.FreeThrowsMade;
            TeamTotals.FreeThrowsAttempted += s.Stats.FreeThrowsAttempted;
            TeamTotals.Rebounds += s.Stats.Rebounds;
            TeamTotals.Assists += s.Stats.Assists;
            TeamTotals.Steals += s.Stats.Steals;
            TeamTotals.Blocks += s.Stats.Blocks;
            TeamTotals.Turnovers += s.Stats.Turnovers;
            TeamTotals.Fouls += s.Stats.Fouls;

        }
    }

    private void FinalizePlayerStats(BasketballTotalsModel totals, BasketballPlayerStats playerStats, int gamesPlayed)
    {
        playerStats.MinutesPerGame = SafeAvg(totals.Minutes, gamesPlayed);
        playerStats.PointsPerGame = SafeAvg(totals.Points, gamesPlayed);
        playerStats.ReboundsPerGame = SafeAvg(totals.Rebounds, gamesPlayed);
        playerStats.AssistsPerGame = SafeAvg(totals.Assists, gamesPlayed);
        playerStats.StealsPerGame = SafeAvg(totals.Steals, gamesPlayed);
        playerStats.BlocksPerGame = SafeAvg(totals.Blocks, gamesPlayed);
        playerStats.TurnoversPerGame = SafeAvg(totals.Turnovers, gamesPlayed);
        playerStats.FoulsPerGame = SafeAvg(totals.Fouls, gamesPlayed);
        playerStats.FieldGoalsMadePerGame = SafeAvg(totals.FieldGoalsMade, gamesPlayed);
        playerStats.FieldGoalsAttemptedPerGame = SafeAvg(totals.FieldGoalsAttempted, gamesPlayed);
        playerStats.FieldGoalPercentage = SafePct(totals.FieldGoalsMade, totals.FieldGoalsAttempted);
        playerStats.ThreePointersMadePerGame = SafeAvg(totals.ThreePointersMade, gamesPlayed);
        playerStats.ThreePointersAttemptedPerGame = SafeAvg(totals.ThreePointersAttempted, gamesPlayed);
        playerStats.ThreePointPercentage = SafePct(totals.ThreePointersMade, totals.ThreePointersAttempted);
        playerStats.FreeThrowsMadePerGame = SafeAvg(totals.FreeThrowsMade, gamesPlayed);
        playerStats.FreeThrowsAttemptedPerGame = SafeAvg(totals.FieldGoalsAttempted, gamesPlayed);
        playerStats.FreeThrowPercentage = SafePct(totals.FreeThrowsMade, totals.FreeThrowsAttempted);

    }

    private void FinalizeTeamStats(int teamGames)
    {
        TeamTotals.PointsAverage = SafeAvg(TeamTotals.Minutes, teamGames);
        TeamTotals.ReboundsAverage = SafeAvg(TeamTotals.Rebounds, teamGames);
        TeamTotals.AssistsAverage = SafeAvg(TeamTotals.Assists, teamGames);
        TeamTotals.StealsAverage = SafeAvg(TeamTotals.Steals, teamGames);
        TeamTotals.BlocksAverage = SafeAvg(TeamTotals.Blocks, teamGames);
        TeamTotals.FieldGoalPercentage = SafePct(TeamTotals.FieldGoalsMade, TeamTotals.FieldGoalsAttempted);
        TeamTotals.ThreePointerPercentage = SafePct(TeamTotals.ThreePointersMade, TeamTotals.ThreePointersAttempted);
        TeamTotals.FreeThrowPercentage = SafePct(TeamTotals.FreeThrowsMade, TeamTotals.FreeThrowsAttempted);
    }

    private async Task GetImageAsync(IEnumerable<PlayerModel> players)
    {
        foreach (var player in players)
            player.Image = await ImageService.GetPlayerImageAsync(LeagueModel.League, TeamModel.Team, player);
    }

    private Task OpenStatDialogAsync(string message)
    {
        var parameters = new DialogParameters<StatInfoMessageBox> { { x => x.Message, message } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        return DialogService.ShowAsync<StatInfoMessageBox>("Stat Info", parameters, options);
    }

    private decimal SafeAvg(int numerator, int denominator) =>
        denominator == 0 ? 0 : (decimal)numerator / denominator;

    private decimal SafePct(int made, int attempted) =>
        attempted == 0 ? 0 : (decimal)made / attempted * 100;


    private Task<GetSeasonsResponse> LoadSeasonsAsync() =>
        DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonsCache(),
            () => SeasonService.GetSeasons(),
            (s) => SeasonLocalCache.SetSeasonsCache(s)
    );

    private Task<GetSeasonByYearResponse> LoadSeasonAsync(int year) =>
        DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonByYearCache(year),
            () => SeasonService.GetSeasonByYear(year),
            (s) => SeasonLocalCache.SetSeasonByYearCache(year, s)
    );

    private Task<GetTeamByIdResponse> LoadTeamAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(id.ToString()),
            () => TeamService.GetTeamById(id),
            (t) => TeamLocalCache.SetTeamByIdCache(id.ToString(), t)
    );

    private Task<GetLeagueByIdResponse> LoadLeagueAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeagueByIdCache(id.ToString()),
            () => LeagueService.GetLeague(id),
            (l) => LeagueLocalCache.SetLeagueByIdCache(id.ToString(), l)
    );

    private Task<GetPlayersByTeamResponse> LoadPlayersByTeamAsync(Guid teamId) =>
        DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayersByTeamCache(teamId.ToString()),
            () => PlayerService.GetPlayersByTeam(teamId),
            (p) => PlayerLocalCache.SetPlayersByTeamCache(teamId.ToString(), p)
    );

    private Task<GetPlayerBasketballStatsBySeasonResponse> LoadPlayerStatsBySeasonAsync(Guid id, Guid seasonId) =>
        DataLoader.GetOrLoad(
            () => StatsLocalCache.GetPlayerBasketballStatsBySeasonCache(id.ToString(), seasonId.ToString()),
            () => StatService.GetPlayerBasketballStatsBySeason(id, seasonId),
            (s) => StatsLocalCache.SetPlayerBasketballStatsBySeasonCache(id.ToString(), seasonId.ToString(), s)
    );

    private Task<GetStandingsByTeamResponse> LoadTeamStandingsAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => StandingsLocalCache.GetStandingsByTeamCache(id.ToString()),
            () => StandingsService.GetStandingsByTeam(id),
            (s) => StandingsLocalCache.SetStandingsByTeamCache(id.ToString(), s)
    );

}
