@page "/teams"
@using League.Builder.Web.Server.Services.Cache
@inject NavigationManager NavManager
@inject ILeagueService LeagueService
@inject ITeamService TeamService
@inject IAWSService AWSService
@inject IHttpContextAccessor HttpContextAccessor
@inject ITeamLocalCacheService TeamLocalCache
@inject ILeagueLocalCacheService LeagueLocalCache
@inject ErrorState ErrorState
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService
@inject AuthenticationStateProvider AuthenticationStateProvider

<AuthorizeView Roles="@String.Concat(Roles.ReadTeams, ", ", Roles.ReadLeagues)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="pt-12">
                <MudExpansionPanels Class="border border-solid" Style="border-color: #000000">
                    <MudExpansionPanel Expanded="expandSearchPanel">
                        <TitleContent>
                            <MudText Typo="Typo.h5" Align="Align.Center" Class="font-bold">Teams Search</MudText>
                        </TitleContent>
                        <ChildContent>
                            <MudItem>
                                <MudTabs Elevation="2" Centered="true" Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary" Class="border border-solid pa-6" Style="border-color: #000000">
                                    <MudTabPanel Text="Search All">
                                        <MudItem Class="padtop-20">
                                            <MudButton OnClick="@(() => ExecuteSearch(SearchAllInternal))"
                                                       Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       Class="ml-auto"
                                                       FullWidth="true">
                                                Search All
                                            </MudButton>
                                        </MudItem>
                                    </MudTabPanel>
                                    <MudTabPanel Text="Team Name" Class="padtop-20">
                                        <MudStack Row="true">
                                            <MudItem xs="9">
                                                <MudTextField @bind-Value="teamName" Placeholder="Team Name" />
                                            </MudItem>
                                            <MudItem xs="3">
                                                <MudButton Disabled="@(teamName == string.Empty)"
                                                           OnClick="@(()=> ExecuteSearch(SearchByTeamNameInternal))"
                                                           Variant="Variant.Filled"
                                                           Color="Color.Primary"
                                                           Class="ml-auto"
                                                           Style="width: 200px;">
                                                    Search
                                                </MudButton>
                                            </MudItem>
                                        </MudStack>
                                    </MudTabPanel>
                                    <MudTabPanel Text="State">
                                        <MudStack Row="true" Class="padtop-20">
                                            <MudItem xs="9">
                                                <MudSelect Label="State" @bind-Value="state">
                                                    @foreach (var state in Constants.States())
                                                    {
                                                        <MudSelectItem Value="state">@state</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="3" Style="align-content:center">
                                                <MudButton Disabled="@(state == string.Empty)"
                                                           OnClick="@(()=> ExecuteSearch(SearchByStateInternal))"
                                                           Variant="Variant.Filled"
                                                           Color="Color.Primary"
                                                           Class="ml-auto"
                                                           Style="width: 200px;">
                                                    Search
                                                </MudButton>
                                            </MudItem>
                                        </MudStack>
                                    </MudTabPanel>
                                </MudTabs>
                            </MudItem>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            @if (Model != null)
            {
                <MudItem Class="pt-6">
                    <MudExpansionPanels>
                        <MudExpansionPanel Expanded="true" Class="border border-solid" Style="border-color: #000000">
                            <TitleContent>
                                <MudText Typo="Typo.h5" Align="Align.Center" Class="font-bold">Results</MudText>
                            </TitleContent>
                            <ChildContent>
                                <MudItem>
                                    <MudTable Items="@Model" Hover="true" SortLabel="Sort By" Class="border border-solid" Style="border-color: #000000">
                                        <HeaderContent>
                                            <MudTh Class="mud-theme-primary font-bold"></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(TeamModel x) => x.TeamName">Name</MudTableSortLabel></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(TeamModel x) => x.LeagueName">League</MudTableSortLabel></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(TeamModel x) => x.TeamAddress.FirstName">Team Owner</MudTableSortLabel></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(TeamModel x) => x.TeamAddress.State">Location</MudTableSortLabel></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"></MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="">
                                                <PlayerAvatar Image="@context.Image" />
                                            </MudTd>
                                            <MudTd DataLabel="Team Name">
                                                <MudTooltip Text="Team Details" Color="Color.Secondary">
                                                    <MudLink Color="Color.Tertiary" Href="@($"/playersbyteam/{context.Id}")">@context.TeamName</MudLink>
                                                </MudTooltip>
                                             </MudTd>
                                            <MudTd DataLabel="League">@context.LeagueName</MudTd>
                                            <MudTd DataLabel="Team Owner">@context.TeamAddress.FirstName @context.TeamAddress.LastName</MudTd>
                                            <MudTd DataLabel="Location">@context.TeamAddress.City, @context.TeamAddress.State</MudTd>
                                            <MudTd DataLabel="Links">
                                                @if (CanReadStats)
                                                {
                                                    @if (CanReadGames)
                                                    {
                                                        <MudTooltip Text="Schedule" Color="Color.Secondary">
                                                            <MudIconButton Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Tertiary" Edge="Edge.Start" Href="@($"/teamgames/{context.Id}")" />
                                                        </MudTooltip>

                                                    }
                                                    <MudTooltip Text="Stats" Color="Color.Secondary">
                                                        @if (context.Sport == SportName.BASEBALL)
                                                        {
                                                            <MudIconButton Icon="@Icons.Material.Filled.QueryStats" Color="Color.Tertiary" Edge="Edge.Start" Href="@($"/baseballteamstats/{context.Id}")" />
                                                        }
                                                        @if (context.Sport == SportName.BASKETBALL)
                                                        {
                                                            <MudIconButton Icon="@Icons.Material.Filled.QueryStats" Color="Color.Tertiary" Edge="Edge.Start" Href="@($"/basketballteamstats/{context.Id}")" />
                                                        }
                                                        @if (context.Sport == SportName.FOOTBALL)
                                                        {
                                                            <MudIconButton Icon="@Icons.Material.Filled.QueryStats" Color="Color.Tertiary" Edge="Edge.Start" Href="@($"/footballteamstats/{context.Id}")" />
                                                        }
                                                    </MudTooltip>
                                                }

                                                @if (CanReadTeams)
                                                {
                                                    <MudTooltip Text="Team History" Color="Color.Secondary">
                                                        <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Color="Color.Tertiary" Edge="Edge.Start" Target="_blank" Href="@($"/teamhistory/{context.Id}")" />
                                                    </MudTooltip>
                                                }

                                                @if (CanUpdateTeams)
                                                {
                                                    <MudTooltip Text="Update" Color="Color.Secondary">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Update" Color="Color.Tertiary" Edge="Edge.Start" Href="@($"/updateteam/{context.Id}")" />
                                                    </MudTooltip>
                                                }
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <MudTablePager />
                                        </PagerContent>
                                    </MudTable>

                                </MudItem>
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudItem>
            }
            @if (isSearchLoading)
            {
                <Loading />
            }
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool PageLoad = false;
    private string teamName = string.Empty;
    private string state = string.Empty;
    private string prevTeamName = string.Empty;
    private GetTeamsResponse TeamsResponse { get; set; }
    private GetTeamsByNameResponse TeamsByNameResponse { get; set; }
    private GetTeamsByStateResponse TeamsByStateResponse { get; set; }
    private GetLeaguesResponse LeaguesResponse { get; set; }
    private List<TeamModel> Model { get; set; }
    private bool expandSearchPanel = true;
    private bool isSearchLoading = false;
    private string sport = string.Empty;
    private IJSObjectReference? _module;
    private bool CanReadStats;
    private bool CanReadGames;
    private bool CanReadTeams;
    private bool CanUpdateTeams;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            CanReadStats = user.IsInRole(Roles.ReadStats);
            CanReadGames = user.IsInRole(Roles.ReadGames);
            CanReadTeams = user.IsInRole(Roles.ReadTeams);
            CanUpdateTeams = user.IsInRole(Roles.UpdateTeams);

            LeaguesResponse = await LoadLeaguesAsync();
            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task FinishSearchAsync(IEnumerable<TeamModel> teams)
    {
        Model = teams.ToList();
        await GetImageAsync();
    }

    private async Task ExecuteSearch(Func<Task> searchFunc)
    {
        try
        {
            isSearchLoading = true;
            await searchFunc();
            expandSearchPanel = false;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
        finally
        {
            isSearchLoading = false;
        }
    }

    private async Task SearchAllInternal()
    {
        TeamsResponse = await LoadTeamsAsync();
        await FinishSearchAsync(TeamsResponse.Teams.Data);
    }

    private async Task SearchByTeamNameInternal()
    {
        if (prevTeamName == teamName)
        {
            TeamsByNameResponse = await LoadTeamsByNameAsync(teamName);
        }
        else
        {
            TeamsByNameResponse = await TeamService.GetTeamsByName(teamName);
            await TeamLocalCache.SetTeamsByNameCache(TeamsByNameResponse);
            prevTeamName = teamName;
        }
        await FinishSearchAsync(TeamsByNameResponse.Teams);
    }

    private async Task SearchByStateInternal()
    {
        TeamsByStateResponse = await LoadTeamsByStateAsync(state);

        await FinishSearchAsync(TeamsByStateResponse.Teams);
    }

    private async Task GetImageAsync()
    {
        foreach (var team in Model)
        {
            var league = LeaguesResponse.Leagues.FirstOrDefault(l => l.Id == team.LeagueId);
            team.LeagueName = league.Name;
            team.Sport = league.Sport;
            var keyPath = $"/{league.Sport}/{league.Name}/teams/{team.TeamName}/{team.ImageFile}";
            team.Image = await ImageService.GetTeamImageAsync(league, team);
        }
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private Task<GetLeaguesResponse> LoadLeaguesAsync() =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeaguesCache(),
            () => LeagueService.GetLeagues(),
            (l) => LeagueLocalCache.SetLeaguesCache(l)
    );

    private Task<GetTeamsResponse> LoadTeamsAsync() =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamsCache(),
            () => TeamService.GetTeams(0, 1000),
            (t) => TeamLocalCache.SetTeamsCache(t)
    );

    private Task<GetTeamsByNameResponse> LoadTeamsByNameAsync(string teamName) =>
        DataLoader.GetOrLoad(
                () => TeamLocalCache.GetTeamsByNameCache(),
                () => TeamService.GetTeamsByName(teamName),
                (t) => TeamLocalCache.SetTeamsByNameCache(t)
            );

    private Task<GetTeamsByStateResponse> LoadTeamsByStateAsync(string state) =>
        DataLoader.GetOrLoad(
                () => TeamLocalCache.GetTeamsByStateCache(state),
                () => TeamService.GetTeamsByState(state),
                (t) => TeamLocalCache.SetTeamsByStateCache(state, t)
        );


}
