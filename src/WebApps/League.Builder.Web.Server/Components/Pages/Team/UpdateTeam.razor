@page "/updateteam/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject ITeamService TeamService
@inject ILeagueService LeagueService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject ISnackbar Snackbar
@inject IWebHostEnvironment env
@inject IAWSService AWSService
@inject IValidator<UpdateTeamModel> UpdateTeamValidator
@inject IDialogService DialogService
@inject ILeagueLocalCacheService LeagueLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService

<AuthorizeView Roles="@String.Concat(Roles.UpdateTeams)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="pt-12">
                <MudPaper Class="border border-solid p-25" Style="border-color: #000000;">
                    <MudText Typo="Typo.h4" Align="Align.Center" Class="font-bold">Update @TeamByIdResponse.Team.TeamName</MudText>
                </MudPaper>
            </MudItem>
            <MudItem Class="mt-50 mb-50">
                <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                    <FluentValidationValidator @ref="fluentValidationValidator" />
                    <MudPaper Class="border border-solid p-25" Style="border-color: #000000; width: 100%;">
                        <MudStepper @bind-ActiveIndex="_index" OnPreviewInteraction="@OnStepInteraction" CurrentStepColor="Color.Secondary" CompletedStepColor="Color.Success">
                            <ChildContent>
                                <MudStep Title="Update Team Information">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                    @StepHeader(Icons.Material.Filled.Info, "Team Information")
                                                    <MudTextField Required Label="Team Name" HelperText="Max. 150 characters"
                                                                  @bind-Value="model.TeamName" For="@(() => model.TeamName)" Clearable />
                                                    <MudSelect Required AdornmentColor="Color.Primary" Class="mt-3" Label="Color" @bind-Value="model.TeamColor">
                                                        @foreach (var colors in Constants.Colors())
                                                        {
                                                            <MudSelectItem Value="@colors.Value">
                                                                <div class="d-flex align-center">
                                                                    <div style="@($"background-color: {colors.Value}; width: 20px; height: 20px; margin-right: 10px; border-radius: 4px;")"></div>
                                                                    <MudText>
                                                                        @colors.Key
                                                                    </MudText>
                                                                </div>
                                                            </MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                    <MudSelect Required Class="mt-3" Label="League" @bind-Value="model.LeagueId">
                                                        @foreach (var league in Leagues.Leagues.Where(l => l.Id == model.LeagueId))
                                                        {
                                                            <MudSelectItem Value="league.Id">@league.Name</MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Update Team Admin">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.AdminPanelSettings, "Team Admin")
                                                    <MudTextField Required Label="First Name" Class="mt-3"
                                                                @bind-Value="model.FirstName" For="@(() => model.FirstName)" Clearable />
                                                    <MudTextField Required Label="Last Name" Class="mt-3"
                                                                @bind-Value="model.LastName" For="@(() => model.LastName)" Clearable />
                                                    <MudTextField Required Label="Email Address" Class="mt-3"
                                                                @bind-Value="model.EmailAddress" For="@(() => model.EmailAddress)" Clearable />
                                                    <MudTextField Label="Description" Class="mt-3"
                                                                @bind-Value="model.Description" For="@(() => model.Description)" Clearable />
                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Update Team Manager">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                    @StepHeader(Icons.Material.Filled.Person, "Team Manager")
                                                    <MudTextField Required Label="First Name" Class="mt-3"
                                                                  @bind-Value="model.ManagerFirstName" For="@(() => model.ManagerFirstName)" Clearable/>
                                                    <MudTextField Required Label="Last Name" Class="mt-3"
                                                                  @bind-Value="model.ManagerLastName" For="@(() => model.ManagerLastName)" Clearable/>
                                                    <MudTextField Required Label="Email Address" Class="mt-3"
                                                                  @bind-Value="model.ManagerEmailAddress" For="@(() => model.ManagerEmailAddress)" Clearable />

                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Update Team Address">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                    @StepHeader(Icons.Material.Filled.House, "Team Address")
                                                    <MudTextField Required Label="Address Line" Class="mt-3"
                                                                  @bind-Value="model.AddressLine" For="@(() => model.AddressLine)" Clearable/>
                                                    <MudTextField Required Label="City" Class="mt-3"
                                                                  @bind-Value="model.City" For="@(() => model.City)"  Clearable/>
                                                    <MudSelect Required Class="mt-3" Label="State" @bind-Value="model.State">
                                                        @StateOptions
                                                    </MudSelect>
                                                    <MudSelect Required Class="mt-3" Label="Country" @bind-Value="model.Country">
                                                        @CountryOptions
                                                    </MudSelect>
                                                    <MudTextField Required Label="Zip Code" Class="mt-3"
                                                                  @bind-Value="model.ZipCode" For="@(() => model.ZipCode)" Clearable/>

                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Review">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                    @StepHeader(Icons.Material.Filled.RemoveRedEye, "Review")
                                                    <MudTextField Required Label="Team Name" HelperText="Max. 50 characters"
                                                                  @bind-Value="model.TeamName" For="@(() => model.TeamName)" ReadOnly/>
                                                    <MudSelect Required AdornmentColor="Color.Primary" Class="mt-3" Label="Color" @bind-Value="model.TeamColor" ReadOnly>
                                                        @foreach (var colors in Constants.Colors())
                                                        {
                                                            <MudSelectItem Value="@colors.Value">
                                                                <div class="d-flex align-center">
                                                                    <div style="@($"background-color: {colors.Value}; width: 20px; height: 20px; margin-right: 10px; border-radius: 4px;")"></div>
                                                                    <MudText>
                                                                        @colors.Key
                                                                    </MudText>
                                                                </div>
                                                            </MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                    <MudSelect Required Class="mt-3" Label="League" @bind-Value="model.LeagueId" ReadOnly>
                                                        @foreach (var league in Leagues.Leagues.Where(l => l.Id == model.LeagueId))
                                                        {
                                                            <MudSelectItem Value="league.Id">@league.Name</MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                    <MudTextField Required Label="First Name" Class="mt-3"
                                                                  @bind-Value="model.FirstName" For="@(() => model.FirstName)" ReadOnly />
                                                    <MudTextField Required Label="Last Name" Class="mt-3"
                                                                  @bind-Value="model.LastName" For="@(() => model.LastName)" ReadOnly />
                                                    <MudTextField Required Label="Email Address" Class="mt-3"
                                                                  @bind-Value="model.EmailAddress" For="@(() => model.EmailAddress)" ReadOnly />
                                                    <MudTextField Label="Description" Class="mt-3"
                                                                  @bind-Value="model.Description" For="@(() => model.Description)" ReadOnly />
                                                    <MudTextField Required Label="Manager First Name" Class="mt-3"
                                                                  @bind-Value="model.ManagerFirstName" For="@(() => model.ManagerFirstName)" ReadOnly />
                                                    <MudTextField Required Label="Manager Last Name" Class="mt-3"
                                                                  @bind-Value="model.ManagerLastName" For="@(() => model.ManagerLastName)" ReadOnly />
                                                    <MudTextField Required Label="Manager Email Address" Class="mt-3"
                                                                  @bind-Value="model.ManagerEmailAddress" For="@(() => model.ManagerEmailAddress)" ReadOnly />
                                                    <MudTextField Required Label="Address Line" Class="mt-3"
                                                                  @bind-Value="model.AddressLine" For="@(() => model.AddressLine)" ReadOnly />
                                                    <MudTextField Required Label="City" Class="mt-3"
                                                                  @bind-Value="model.City" For="@(() => model.City)" ReadOnly />
                                                    <MudSelect Required="true" Class="mt-3" Label="State" @bind-Value="model.State" ReadOnly>
                                                        @StateOptions
                                                    </MudSelect>
                                                    <MudSelect Required="true" Class="mt-3" Label="Country" @bind-Value="model.Country" ReadOnly>
                                                        @CountryOptions
                                                    </MudSelect>
                                                    <MudTextField Required Label="Zip Code" Class="mt-3"
                                                                  @bind-Value="model.ZipCode" For="@(() => model.ZipCode)" ReadOnly />
                                                    <MudStack Row="true" Class="padtop-20">
                                                        <MudFileUpload @ref="@_fileUpload"
                                                                       T="IBrowserFile"
                                                                       For="@(() => model.File)"
                                                                       @bind-Files="model.File" CustomContent="UploadButton">
                                                        </MudFileUpload>
                                                    </MudStack>
                                                </div>,
                                            @<MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" FullWidth="true">Update</MudButton>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                            </ChildContent>
                            <ActionContent Context="stepper">
                                <MudIconButton OnClick="@(() => stepper.PreviousStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowBack"
                                               Color="Color.Primary"
                                               Disabled="_index == 0">
                                </MudIconButton>
                                <MudSpacer />
                                <MudIconButton OnClick="@(() => stepper.NextStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowForward"
                                               Color="Color.Primary"
                                               Disabled="_index == 4">
                                </MudIconButton>
                            </ActionContent>
                        </MudStepper>
                    </MudPaper>
                </EditForm>
            </MudItem>
        }
        else
        {
            <Loading />
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>
@code {

    [Parameter]
    public string Id { get; set; }

    private bool PageLoad = false;
    private GetTeamByIdResponse TeamByIdResponse { get; set; }
    private GetLeaguesBySportResponse Leagues { get; set; }
    private GetLeagueByIdResponse League { get; set; }
    private List<string> states;
    private List<string> countries;
    UpdateTeamModel model = new UpdateTeamModel();
    bool uploadFile = false;
    private int _index;
    private bool canProceed = false;
    private List<string> errors = new();
    private MudFileUpload<IBrowserFile> _fileUpload;
    private FluentValidationValidator fluentValidationValidator;
    private IJSObjectReference? _module;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAllAsync();
            MapModel();
            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task LoadAllAsync()
    {
        var teamId = Guid.Parse(Id);
        TeamByIdResponse = await LoadTeamsAsync(teamId);

        League = await LoadLeagueAsync(TeamByIdResponse.Team.LeagueId);

        Leagues = await LoadLeaguesAsync(League.League.Sport);

        states = Constants.States();
        countries = Constants.Countries();
    }

    private void MapModel()
    {
        var t = TeamByIdResponse.Team;

        model.Id = t.Id;
        model.LeagueId = t.LeagueId;
        model.TeamName = t.TeamName;
        model.FirstName = t.TeamAddress.FirstName;
        model.LastName = t.TeamAddress.LastName;
        model.ManagerFirstName = t.TeamManager?.FirstName;
        model.ManagerLastName = t.TeamManager?.LastName;
        model.ManagerEmailAddress = t.TeamManager?.EmailAddress;
        model.AddressLine = t.TeamAddress.AddressLine;
        model.City = t.TeamAddress.City;
        model.EmailAddress = t.TeamAddress.EmailAddress;
        model.State = t.TeamAddress.State;
        model.Country = t.TeamAddress.Country;
        model.ZipCode = t.TeamAddress.ZipCode;
        model.Description = t.Description;
        model.ImageFile = t.ImageFile;
        model.TeamColor = t.TeamColor;
        model.TeamStatus = t.TeamStatus;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        try
        {
            await HandleImageUpdateAsync();
            await UpdateTeamRecordAsync();
            await ClearTeamCache();
            Snackbar.Add("Team has been updated.", MudBlazor.Severity.Success);
            NavManager.NavigateTo($"/teamsbyleague/{model.LeagueId.ToString()}");
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task HandleImageUpdateAsync()
    {
        var oldName = TeamByIdResponse.Team.TeamName;

        if (model.TeamName != TeamByIdResponse.Team.TeamName)
        {
            if (model.File is null)
            {
                await ImageService.CopyTeamImageForUpdateAsync(League.League, TeamByIdResponse.Team, model);

            }
            else
            {
                model.ImageFile = model.File.Name;
                await ImageService.CopyTeamImageForUpdateAsync(League.League, TeamByIdResponse.Team, model);
            }

        }
        else
        {
            if (model.File is not null)
            {
                model.ImageFile = model.File.Name;
                await ImageService.UploadUpdatedTeamImageAsync(League.League, model);
            }
        }
    }

    private async Task UpdateTeamRecordAsync()
    {
        Models.Team.AddressModel address = new Models.Team.AddressModel(model.FirstName, model.LastName, model.EmailAddress, model.AddressLine, model.City, model.Country, model.State, model.ZipCode);
        Models.Team.ManagerModel manager = new Models.Team.ManagerModel(model.ManagerFirstName, model.ManagerLastName, model.ManagerEmailAddress);
        UpdateTeamRequest request = new UpdateTeamRequest(new UpdateTeamRecord(model.Id, model.LeagueId, model.TeamName, address, model.Description, model.ImageFile, model.TeamColor, (int)model.TeamStatus, manager));
        await TeamService.UpdateTeam(request);
    }

    private async Task ClearTeamCache()
    {
        await TeamLocalCache.DeleteTeamsCache();
        await TeamLocalCache.DeleteTeamsByNameCache();

        foreach (var state in Constants.States())
            await TeamLocalCache.DeleteTeamsByStateCache(state);

        await TeamLocalCache.DeleteTeamByIdCache(Id);
        await TeamLocalCache.DeleteTeamsByLeagueCache(model.LeagueId.ToString());
    }

    private async Task OnStepInteraction(StepperInteractionEventArgs args)
    {
        canProceed = false;
        await ValidateCurrentStep();
        if (args.Action == StepAction.Complete && !canProceed)
        {
            await OpenErrorDialogAsync();
            args.Cancel = true;

        }
    }

    private async Task ValidateCurrentStep()
    {
        errors.Clear();

        var properties = _index switch
        {
            0 => new[] { nameof(UpdateTeamModel.TeamName) },
            1 => new[] { nameof(UpdateTeamModel.FirstName), nameof(UpdateTeamModel.LastName), nameof(UpdateTeamModel.EmailAddress) },
            2 => new[] { nameof(UpdateTeamModel.ManagerFirstName), nameof(UpdateTeamModel.ManagerLastName), nameof(UpdateTeamModel.ManagerEmailAddress) },
            3 => new[] { nameof(UpdateTeamModel.AddressLine), nameof(UpdateTeamModel.State), nameof(UpdateTeamModel.Country), nameof(UpdateTeamModel.ZipCode) },
            _ => Array.Empty<string>()
        };

        if (properties.Length == 0)
        {
            canProceed = true;
            return;
        }

        var result = await UpdateTeamValidator.ValidateAsync(
            model,
            options => options.IncludeProperties(properties)
        );

        canProceed = result.IsValid;

        foreach (var error in result.Errors)
            errors.Add(error.ErrorMessage);
    }

    private Task OpenErrorDialogAsync()
    {
        var parameters = new DialogParameters<ErrorMessageBox> { { x => x.Errors, errors } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        return DialogService.ShowAsync<ErrorMessageBox>("Errors", parameters, options);
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private Task<GetTeamByIdResponse> LoadTeamsAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(id.ToString()),
            () => TeamService.GetTeamById(id),
            (t) => TeamLocalCache.SetTeamByIdCache(id.ToString(), t)
    );

    private Task<GetLeagueByIdResponse> LoadLeagueAsync(Guid leagueId) =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeagueByIdCache(leagueId.ToString()),
            () => LeagueService.GetLeague(leagueId),
            (l) => LeagueLocalCache.SetLeagueByIdCache(leagueId.ToString(), l)
    );

    private Task<GetLeaguesBySportResponse> LoadLeaguesAsync(string sport) =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeaguesBySportCache(sport),
            () => LeagueService.GetLeaguesBySport(sport),
            (l) => LeagueLocalCache.SetLeaguesBySportCache(sport, l)
    );

    private Func<string, string, RenderFragment> StepHeader = (string icon, string title) => @<MudStack Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Row="true">
            <MudIcon Icon="@icon" Color="Color.Secondary" Size="Size.Medium" />
            <MudText Typo="Typo.h6" Class="font-bold">@title</MudText>
    </MudStack>;

    private RenderFragment Card(RenderFragment content, RenderFragment actions = null) => @<MudCard Class="border border-solid border-black">
        <MudCardContent>
            @content
        </MudCardContent>
        @if (actions is not null)
        {
                <MudCardActions>
                    @actions
                </MudCardActions>
        }
    </MudCard>;

    private RenderFragment<MudFileUpload<IBrowserFile>> UploadButton =>
        (fileUpload) => @<MudButton Variant="Variant.Filled"
                                            Color="Color.Primary"
                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                            OnClick="@(() => fileUpload.OpenFilePickerAsync())">
            Team Image
    </MudButton>;

    private RenderFragment StateOptions => __builder =>
    {
        foreach (var state in states)
        {
            <MudSelectItem Value="@state">@state</MudSelectItem>
            ;
        }
    };

    private RenderFragment CountryOptions => __builder =>
    {
        foreach (var country in countries)
        {
            <MudSelectItem Value="@country">@country</MudSelectItem>                
            ;
        }
    };
}
