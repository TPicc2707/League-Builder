<MudTable Items="@Rows" Hover="true" Class="border border-solid" Style="border-color: #000000">
    <HeaderContent>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">VS</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">AB</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">R</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">H</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">RBI</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">BB</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">HBP</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">K</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">SB</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">TB</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">2B</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">3B</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">HR</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">SF</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Opposing Team" Style="font-size: 12px;">
            <div style="display: flex; align-items: center; gap: 6px;">
                <PlayerAvatar Image="@context.OpposingTeamImage" />
                <span>@context.OpposingTeam</span>
            </div>
        </MudTd>
        <MudTd DataLabel="At Bats" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.AtBats</MudTd>
        <MudTd DataLabel="Runs">@context.BaseballStatsModel.HittingStats.Runs</MudTd>
        <MudTd DataLabel="Hits">@context.BaseballStatsModel.HittingStats.Hits</MudTd>
        <MudTd DataLabel="RBI" Style="margin-left: 7px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.RunsBattedIn</MudTd>
        <MudTd DataLabel="BB" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.Walks</MudTd>
        <MudTd DataLabel="HBP" Style="margin-left: 7px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.HitByPitch</MudTd>
        <MudTd DataLabel="K" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.Strikeouts</MudTd>
        <MudTd DataLabel="SB" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.StolenBases</MudTd>
        <MudTd DataLabel="TB" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.TotalBases</MudTd>
        <MudTd DataLabel="2B" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.Doubles</MudTd>
        <MudTd DataLabel="3B" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.Triples</MudTd>
        <MudTd DataLabel="HR" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.HomeRuns</MudTd>
        <MudTd DataLabel="SF" Style="margin-left: 5px; font-size: .875rem;">@context.BaseballStatsModel.HittingStats.SacrificeFly</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter] public IEnumerable<PlayerStatRecord> Rows { get; set; }
    [Parameter] public string TeamColor { get; set; }
}
