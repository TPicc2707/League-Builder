<MudItem Style="padding-top: 25px;">
    <MudTable Items="@Stats" Hover="true" Class="border border-solid" Style="border-color: #000000">
        <ColGroup>
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
        </ColGroup>
        <HeaderContent>
            <MudTh Class="mud-theme-primary font-bold">Name</MudTh>
            <MudTh Class="mud-theme-primary font-bold">CAR</MudTh>
            <MudTh Class="mud-theme-primary font-bold">YDS</MudTh>
            <MudTh Class="mud-theme-primary font-bold">TD</MudTh>
            <MudTh Class="mud-theme-primary font-bold">LNG</MudTh>
            <MudTh Class="mud-theme-primary font-bold">FUM</MudTh>
            <MudTh Class="mud-theme-primary font-bold">LST</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name" Style="font-size: 12px;">@context.PlayerName</MudTd>
            <MudTd DataLabel="Carries">@context.RushingAttempts</MudTd>
            <MudTd DataLabel="Yards">@context.RushingYards</MudTd>
            <MudTd DataLabel="Touchdowns">@context.RushingTouchdowns</MudTd>
            <MudTd DataLabel="Longest">@context.LongestRushingPlay</MudTd>
            <MudTd DataLabel="Fumbles">@context.RushingFumbles</MudTd>
            <MudTd DataLabel="Fumbles Lost">@context.RushingFumblesLost</MudTd>
        </RowTemplate>
    </MudTable>
</MudItem>

@code {
    [Parameter] public IEnumerable<FootballGameStatsModel> Stats { get; set; }
}
