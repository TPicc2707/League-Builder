<MudTable Items="@Rows" Hover="true" Class="border border-solid" Style="border-color: #000000">
        <HeaderContent>
            <MudTh Class="mud-theme-primary font-bold">VS</MudTh>
            <MudTh Class="mud-theme-primary font-bold">CMP</MudTh>
            <MudTh Class="mud-theme-primary font-bold">ATT</MudTh>
            <MudTh Class="mud-theme-primary font-bold">YDS</MudTh>
            <MudTh Class="mud-theme-primary font-bold">TD</MudTh>
            <MudTh Class="mud-theme-primary font-bold">INT</MudTh>
            <MudTh Class="mud-theme-primary font-bold">LNG</MudTh>
            <MudTh Class="mud-theme-primary font-bold">S</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Opposing Team" Style="font-size: 12px;">@context.OpposingTeam</MudTd>
            <MudTd DataLabel="Completions">@context.FootballStatsModel.OffensiveStats.PassingCompletions</MudTd>
            <MudTd DataLabel="Attempts">@context.FootballStatsModel.OffensiveStats.PassingAttempts</MudTd>
            <MudTd DataLabel="Yards">@context.FootballStatsModel.OffensiveStats.PassingYards</MudTd>
            <MudTd DataLabel="Touchdowns">@context.FootballStatsModel.OffensiveStats.PassingTouchdowns</MudTd>
            <MudTd DataLabel="Interceptions">@context.FootballStatsModel.OffensiveStats.PassingInterceptions</MudTd>
            <MudTd DataLabel="Longest">@context.FootballStatsModel.OffensiveStats.LongestPassingPlay</MudTd>
            <MudTd DataLabel="Sacks">@context.FootballStatsModel.OffensiveStats.Sacks</MudTd>
        </RowTemplate>
</MudTable>
@code {
    [Parameter] public IEnumerable<PlayerStatRecord> Rows { get; set; }
}
