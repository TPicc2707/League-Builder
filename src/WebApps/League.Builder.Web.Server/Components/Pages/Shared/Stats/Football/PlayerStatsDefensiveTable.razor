<MudTable Items="@Rows" Hover="true" Class="border border-solid" Style="border-color: #000000">
    <HeaderContent>
        <MudTh Class="mud-theme-primary font-bold">VS</MudTh>
        <MudTh Class="mud-theme-primary font-bold">TOT</MudTh>
        <MudTh Class="mud-theme-primary font-bold">SACK</MudTh>
        <MudTh Class="mud-theme-primary font-bold">TFL</MudTh>
        <MudTh Class="mud-theme-primary font-bold">FF</MudTh>
        <MudTh Class="mud-theme-primary font-bold">FR</MudTh>
        <MudTh Class="mud-theme-primary font-bold">INT</MudTh>
        <MudTh Class="mud-theme-primary font-bold">YDS</MudTh>
        <MudTh Class="mud-theme-primary font-bold">TD</MudTh>
        <MudTh Class="mud-theme-primary font-bold">LNG</MudTh>
        <MudTh Class="mud-theme-primary font-bold">PD</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Opposing Team" Style="font-size: 12px;">@context.OpposingTeam</MudTd>
        <MudTd DataLabel="TOT">@context.FootballStatsModel.DefensiveStats.Tackles</MudTd>
        <MudTd DataLabel="SACKS">@context.FootballStatsModel.DefensiveStats.Sacks</MudTd>
        <MudTd DataLabel="TFL">@context.FootballStatsModel.DefensiveStats.TacklesForLoss</MudTd>
        <MudTd DataLabel="FF">@context.FootballStatsModel.DefensiveStats.ForcedFumbles</MudTd>
        <MudTd DataLabel="FR">@context.FootballStatsModel.DefensiveStats.RecoveredFumbles</MudTd>
        <MudTd DataLabel="INT">@context.FootballStatsModel.DefensiveStats.DefensiveInterceptions</MudTd>
        <MudTd DataLabel="YDS">@context.FootballStatsModel.DefensiveStats.DefensiveInterceptionYards</MudTd>
        <MudTd DataLabel="TD">@context.FootballStatsModel.DefensiveStats.DefensiveTouchdowns</MudTd>
        <MudTd DataLabel="LNG">@context.FootballStatsModel.DefensiveStats.LongestDefensiveInterceptionPlay</MudTd>
        <MudTd DataLabel="PD">@context.FootballStatsModel.DefensiveStats.PassesDefended</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter] public IEnumerable<PlayerStatRecord> Rows { get; set; }
}
