<MudTable Items="@Rows" Hover="true" Class="border border-solid" Style="border-color: #000000">
    <HeaderContent>
        <MudTh Class="mud-theme-primary"></MudTh>
        <MudTh Class="mud-theme-primary font-bold">Name</MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.TotalGamesPlayed">GP</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.RushingAttempts">CAR</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.RushingYards">YDS</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.ReceivingYardsPerPlay">AVG</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.ReceivingTouchdowns">TDS</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.LongestRushingPlay">LNG</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.RushingYardsPerGame">YDS/G</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.RushingFumbles">FUM</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.RushingFumblesLost">LST</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="">
            <PlayerAvatar Image="@context.Image" />
        </MudTd>
        <MudTd DataLabel="Name" Style="font-size:smaller">@context.FirstName @context.LastName</MudTd>
        <MudTd DataLabel="GamesPlayed" Style="margin-left: 5px; font-size: .875rem;">@context.FootballStatsModel.TotalGamesPlayed</MudTd>
        <MudTd DataLabel="Carries" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.RushingAttempts</MudTd>
        <MudTd DataLabel="Yards" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.RushingYards</MudTd>
        <MudTd DataLabel="Rushing Yards Average" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.RushingYardsAverage.ToString("#0.0")</MudTd>
        <MudTd DataLabel="Touchdowns" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.RushingTouchdowns</MudTd>
        <MudTd DataLabel="Longest" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.LongestRushingPlay</MudTd>
        <MudTd DataLabel="Rushing Yards Per Game" Style="margin-left: 11px; font-size: .875rem;">@context.RushingYardsPerGame.ToString("#0.0")</MudTd>
        <MudTd DataLabel="Fumbles" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.RushingFumbles</MudTd>
        <MudTd DataLabel="Fumbles Lost" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.RushingFumblesLost</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter] public IEnumerable<PlayerStatsRecord> Rows { get; set; }
}
