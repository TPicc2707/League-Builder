<MudTable Items="@Rows" Hover="true" SortLabel="Sort By" Class="border border-solid" Style="border-color: #000000">
    <HeaderContent>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")"><MudTableSortLabel SortBy="(StandingsModel x) => x.StandingsDetail.Wins">Season</MudTableSortLabel></MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")"><MudTableSortLabel SortBy="(StandingsModel x) => x.StandingsDetail.Wins">Wins</MudTableSortLabel></MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")"><MudTableSortLabel SortBy="(StandingsModel x) => x.StandingsDetail.Losses">Losses</MudTableSortLabel></MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")"><MudTableSortLabel SortBy="(StandingsModel x) => x.WinPercentage">PCT</MudTableSortLabel></MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">Playoffs</MudTh>
        <MudTh Class="font-bold" Style="@($"background-color: {TeamColor}")">League Champion</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Season">
            <MudText Class="ml-1">@context.Year</MudText>
        </MudTd>
        <MudTd DataLabel="Wins">
            <MudText Class="ml-3">@context.StandingsDetail.Wins</MudText>
        </MudTd>
        <MudTd DataLabel="Losses">
            <MudText Class="ml-4">@context.StandingsDetail.Losses</MudText>
        </MudTd>
        <MudTd DataLabel="Win Percentage">
            <MudText>@context.WinPercentage.ToString("#.000")</MudText>
        </MudTd>
        <MudTd DataLabel="Playoffs">
            <MudText Class="ml-4">
                <MudIcon Color="Color.Error" Icon="@Icons.Material.Filled.Clear" />
            </MudText>
        </MudTd>
        <MudTd DataLabel="League Champion">
            <MudText Class="ml-10">
                <MudIcon Color="Color.Error" Icon="@Icons.Material.Filled.Clear" />
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>


@code {
    [Parameter] public IEnumerable<StandingsModel> Rows { get; set; }
    [Parameter] public string TeamColor { get; set; }
}
