<MudTable Items="@Rows" Hover="true" Class="border border-solid" Style="border-color: #000000">
    <HeaderContent>
        <MudTh Class="mud-theme-primary"></MudTh>
        <MudTh Class="mud-theme-primary font-bold">Name</MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.TotalGamesPlayed">GP</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.Receptions">REC</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.Targets">TGTS</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.ReceivingYards">YDS</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.ReceivingYardsPerPlay">AVG</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.ReceivingTouchdowns">TDS</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.ReceivingYardsPerGame">YDS/G</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.YardsAfterCatch">YAC</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.RushingFumbles">FUM</MudTableSortLabel></MudTh>
        <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerStatsRecord x) => x.FootballStatsModel.OffensiveStatsModel.ReceivingFumblesLost">LST</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="">
            <PlayerAvatar Image="@context.Image" />
        </MudTd>
        <MudTd DataLabel="Name" Style="font-size:smaller">@context.FirstName @context.LastName</MudTd>
        <MudTd DataLabel="GamesPlayed" Style="margin-left: 5px; font-size: .875rem;">@context.FootballStatsModel.TotalGamesPlayed</MudTd>
        <MudTd DataLabel="Receptions" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.Receptions</MudTd>
        <MudTd DataLabel="Targets" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.Targets</MudTd>
        <MudTd DataLabel="Yards" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.ReceivingYards</MudTd>
        <MudTd DataLabel="Yards" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.ReceivingYardsPerPlay</MudTd>
        <MudTd DataLabel="Touchdowns" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.ReceivingTouchdowns</MudTd>
        <MudTd DataLabel="Touchdowns" Style="margin-left: 11PX; font-size: .875rem;">@context.ReceivingYardsPerGame</MudTd>
        <MudTd DataLabel="Yards After Catch" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.YardsAfterCatch</MudTd>
        <MudTd DataLabel="Fumbles" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.ReceivingFumbles</MudTd>
        <MudTd DataLabel="Fumbles Lost" Style="margin-left: 7px; font-size: .875rem;">@context.FootballStatsModel.OffensiveStatsModel.ReceivingFumblesLost</MudTd>
    </RowTemplate>
</MudTable>

@code {
        [Parameter] public IEnumerable<PlayerStatsRecord> Rows { get; set; }
}
