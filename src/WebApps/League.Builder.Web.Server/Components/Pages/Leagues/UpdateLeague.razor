@page "/updateleague/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject ILeagueService LeagueService
@inject ITeamService TeamService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject ISnackbar Snackbar
@inject IAWSService AWSService
@inject IValidator<UpdateLeagueModel> UpdateLeagueValidator
@inject IDialogService DialogService
@inject ILeagueLocalCacheService LeagueLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService

<AuthorizeView Roles="@String.Concat(Roles.UpdateLeagues)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem class="mt-50">
                <MudPaper Class="border border-solid pa-6" Style="border-color: #000000;">
                    <MudText Typo="Typo.h4" Align="Align.Center" Class="font-bold">Update @LeagueByIdResponse.League.Name</MudText>
                </MudPaper>
            </MudItem>
            // Add image selection when next version is worked
            <MudItem Class="mt-50 mb-50">
                <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                    <FluentValidationValidator @ref="fluentValidationValidator" />
                    <MudPaper Class="border border-solid pa-6" Style="border-color: #000000; width: 100%;">
                        <MudStepper @bind-ActiveIndex="_index" OnPreviewInteraction="@OnStepInteraction" CurrentStepColor="Color.Secondary" CompletedStepColor="Color.Success">
                            <ChildContent>
                                <MudStep Title="Update League Information">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.Info, "League Information")
                                                <MudTextField Required Label="League Name" HelperText="Max. 150 characters"
                                                              @bind-Value="model.Name" For="@(() => model.Name)" />
                                                 <MudSelect Required Class="mt-3" Label="Sport" @bind-Value="model.Sport">
                                                        @SportOptions
                                                </MudSelect>
                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Update League Admin">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.AdminPanelSettings, "League Admin")
                                                <MudTextField Required Label="First Name" Class="mt-3"
                                                              @bind-Value="model.OwnerFirstName" For="@(() => model.OwnerFirstName)" />
                                                <MudTextField Required Label="Last Name" Class="mt-3"
                                                              @bind-Value="model.OwnerLastName" For="@(() => model.OwnerLastName)" />
                                                <MudTextField Required Label="Email Address" Class="mt-3"
                                                              @bind-Value="model.EmailAddress" For="@(() => model.EmailAddress)" />
                                                <MudTextField Label="Description" Class="mt-3"
                                                              @bind-Value="model.Description" For="@(() => model.Description)" />
                                            </div>)                                           
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Review">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.RemoveRedEye, "Review")
                                                <MudTextField Required Label="League Name" HelperText="Max. 150 characters"
                                                              @bind-Value="model.Name" For="@(() => model.Name)" ReadOnly />
                                                <MudSelect Required Class="mt-3" Label="Sport" @bind-Value="model.Sport" ReadOnly>
                                                    @SportOptions
                                                </MudSelect>
                                                <MudTextField Required Label="First Name" Class="mt-3" ReadOnly
                                                              @bind-Value="model.OwnerFirstName" For="@(() => model.OwnerFirstName)" />
                                                <MudTextField Required Label="Last Name" Class="mt-3" ReadOnly
                                                              @bind-Value="model.OwnerLastName" For="@(() => model.OwnerLastName)" />
                                                <MudTextField Required Label="Email Address" Class="mt-3" ReadOnly
                                                              @bind-Value="model.EmailAddress" For="@(() => model.EmailAddress)" />
                                                <MudTextField Label="Description" Class="mt-3" ReadOnly
                                                              @bind-Value="model.Description" For="@(() => model.Description)" />
                                                <MudItem Style="padding-top: 20px;">
                                                    <MudStack Row="true">
                                                        <MudFileUpload @ref="@_fileUpload"
                                                                       T="IBrowserFile"
                                                                       For="@(() => model.File)"
                                                                       @bind-Files="model.File">
                                                            <ActivatorContent>
                                                                <MudButton Variant="Variant.Filled"
                                                                           Color="Color.Primary"
                                                                           StartIcon="@Icons.Material.Filled.CloudUpload">
                                                                    League Image
                                                                </MudButton>
                                                            </ActivatorContent>
                                                        </MudFileUpload>
                                                        @if (model.File != null)
                                                        {
                                                            <MudText Typo="@Typo.h6">@model.File.Name</MudText>
                                                        }
                                                    </MudStack>
                                                </MudItem>                                          
                                                </div>, 
                                                @<MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" FullWidth="true">Update</MudButton>)                                            
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                            </ChildContent>
                            <ActionContent Context="stepper">
                                <MudIconButton OnClick="@(() => stepper.PreviousStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowBack"
                                               Color="Color.Primary"
                                               Disabled="_index == 0">
                                </MudIconButton>
                                <MudSpacer />
                                <MudIconButton OnClick="@(() => stepper.NextStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowForward"
                                               Color="Color.Primary"
                                               Disabled="_index == 2">
                                </MudIconButton>
                            </ActionContent>
                        </MudStepper>
                    </MudPaper>
                </EditForm>
            </MudItem>
        }
        else
        {
            <Loading />
        }

    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>
@code {

    [Parameter]
    public string Id { get; set; }

    private bool PageLoad = false;
    private GetLeagueByIdResponse LeagueByIdResponse { get; set; }
    private GetTeamsByLeagueResponse TeamsByLeagueResponse { get; set; }
    UpdateLeagueModel model = new UpdateLeagueModel();
    bool success;
    bool uploadFile = false;
    bool disableSportDropdown = false;
    private MudFileUpload<IBrowserFile> _fileUpload;
    private int _index;
    private bool canProceed = false;
    private List<string> errors = new();
    private FluentValidationValidator fluentValidationValidator;
    private IJSObjectReference? _module;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var leagueId = Guid.Parse(Id);
            LeagueByIdResponse = await DataLoader.GetOrLoad(
                () => LeagueLocalCache.GetLeagueByIdCache(Id),
                () => LeagueService.GetLeague(leagueId),
                (l) => LeagueLocalCache.SetLeagueByIdCache(Id, l)
            );

            TeamsByLeagueResponse = await DataLoader.GetOrLoad(
                () => TeamLocalCache.GetTeamsByLeagueCache(Id),
                () => TeamService.GetTeamsByLeague(leagueId),
                (t) => TeamLocalCache.SetTeamsByLeagueCache(Id, t)
            );

            disableSportDropdown = TeamsByLeagueResponse.Teams.Any();

            var league = LeagueByIdResponse.League;
            model = new UpdateLeagueModel
            {
                Id = LeagueByIdResponse.League.Id,
                Name = LeagueByIdResponse.League.Name,
                OwnerFirstName = LeagueByIdResponse.League.OwnerFirstName,
                OwnerLastName = LeagueByIdResponse.League.OwnerLastName,
                Sport = LeagueByIdResponse.League.Sport,
                EmailAddress = LeagueByIdResponse.League.EmailAddress,
                Description = LeagueByIdResponse.League.Description,
                ImageFile = LeagueByIdResponse.League.ImageFile,
            };

            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private static string BuildKey(string sport, string leagueName, string fileName)
        => $"/{sport}/{leagueName}/{fileName}";

    private async Task OnValidSubmit(EditContext context)
    {
        try
        {
            var original = LeagueByIdResponse.League;
            var nameChanged = model.Name != original.Name;
            var newFileUploaded = model.File != null;

            if (nameChanged)
            {
                var oldKey = BuildKey(model.Sport, original.Name, model.ImageFile);
                var newKey = BuildKey(model.Sport, model.Name, newFileUploaded ? model.File.Name : model.ImageFile);

                if (newFileUploaded)
                    model.ImageFile = model.File.Name;

                await AWSService.CopyObjectToNewFolder(oldKey, newKey);
                await AWSService.DeleteObject(oldKey);

            }
            else if (newFileUploaded)
            {
                model.ImageFile = model.File.Name;
                var uploadKey = BuildKey(model.Sport, model.Name, model.File.Name);
                await AWSService.UploadImages(uploadKey, model.File);
            }

            var request = new UpdateLeagueRequest(
                model.Id, 
                model.Name, 
                model.Sport, 
                model.Description, 
                model.ImageFile, 
                model.OwnerFirstName, 
                model.OwnerLastName,
                model.EmailAddress
            );

            await LeagueService.UpdateLeague(request);

            await LeagueLocalCache.DeleteLeaguesCache();
            await LeagueLocalCache.DeleteLeagueBySportCache(model.Sport);
            await LeagueLocalCache.DeleteLeagueByNameCache();
            await LeagueLocalCache.DeleteLeagueByIdCache(Id);

            Snackbar.Add("League has been updated.", MudBlazor.Severity.Success);
            NavManager.NavigateTo("/leagues");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task OnStepInteraction(StepperInteractionEventArgs args)
    {
        canProceed = await ValidateStepAsync(_index);

        if (args.Action == StepAction.Complete)
        {
            if (!canProceed)
            {
                await OpenErrorDialogAsync();
                args.Cancel = true;
            }

        }
    }

    private async Task<bool> ValidateStepAsync(int index)
    {
        errors.Clear();

        var properties = index switch
        {
            0 => new[] { nameof(CreateLeagueModel.Name), nameof(CreateLeagueModel.Sport) },
            1 => new[] { nameof(CreateLeagueModel.OwnerFirstName), nameof(CreateLeagueModel.OwnerLastName), nameof(CreateLeagueModel.EmailAddress) },
            _ => Array.Empty<string>()
        };

        var result = await UpdateLeagueValidator.ValidateAsync(model, opts => opts.IncludeProperties(properties));

        if (!result.IsValid)
            errors.AddRange(result.Errors.Select(e => e.ErrorMessage));

        return result.IsValid;
    }

    private Task OpenErrorDialogAsync()
    {
        var parameters = new DialogParameters<ErrorMessageBox> { { x => x.Errors, errors } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        return DialogService.ShowAsync<ErrorMessageBox>("Errors", parameters, options);
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private RenderFragment SportOptions => __builder =>
    {
        foreach (var sports in Constants.Sports())
        {
            <MudSelectItem Value="@sports">@sports</MudSelectItem>
            ;
        }
    };

    private RenderFragment Card(RenderFragment content, RenderFragment actions = null) =>
    @<MudCard Class="border border-solid border-black">
            <MudCardContent>
                @content
            </MudCardContent>
        @if (actions is not null)
        {
                <MudCardActions>
                    @actions
                </MudCardActions>
        }
    </MudCard>;

    private Func<string, string, RenderFragment> StepHeader = (string icon, string title) => @<MudStack Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Row="true">
        <MudIcon Icon="@icon" Color="Color.Secondary" Size="Size.Medium" />
        <MudText Typo="Typo.h6" Class="font-bold">@title</MudText>
    </MudStack>;
}