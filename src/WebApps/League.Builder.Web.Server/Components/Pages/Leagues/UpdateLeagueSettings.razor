@page "/updateleaguesettings/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject ILeagueService LeagueService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject ISnackbar Snackbar
@inject IValidator<UpdateLeagueSettingsModel> UpdateLeagueSettingsValidator
@inject ILeagueLocalCacheService LeagueLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService

<AuthorizeView Roles="@String.Concat(Roles.UpdateLeagues)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="mt-50">
                <MudPaper Class="border border-solid pa-6" Style="border-color: #000000;">
                    <MudText Typo="Typo.h6" Align="Align.Center" Class="font-bold">@LeagueByIdResponse.League.Name League Settings</MudText>
                </MudPaper>
            </MudItem>

            <MudGrid Justify="Justify.Center">
                <MudItem Class="mt-4" xs="12" sm="9">
                    <MudCard Class="border border-solid pa-8" Style="border-color: #000000">
                        <EditForm Model="@model" OnValidSubmit="OnSubmit">
                            <MudCardContent Class="pa-6">
                                <FluentValidationValidator @ref="fluentValidationValidator" />
                                <MudTextField @bind-Value="model.TotalGamesPerSeason"
                                              For="@(() => model.TotalGamesPerSeason)"
                                                Label="Total Games" />
                                <MudTextField @bind-Value="model.TotalPlayoffTeams"
                                              For="@(() => model.TotalPlayoffTeams)"
                                              Label="Total Playoff Teams" Class="mt-4" />
                                <MudTextField @bind-Value="model.MinimumTotalTeamPlayers"
                                              For="@(() => model.MinimumTotalTeamPlayers)"
                                              Label="Minimum Number of Players On Team" Class="mt-4"/>
                                <MudTextField @bind-Value="model.MaximumTotalTeamPlayers"
                                              For="@(() => model.MaximumTotalTeamPlayers)"
                                              Label="Max Number of Players On Team" class="mt-4"/>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" FullWidth="true">Update</MudButton>
                            </MudCardActions>
                        </EditForm>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set; }
    private bool PageLoad = false;
    UpdateLeagueSettingsModel model = new UpdateLeagueSettingsModel();
    private GetLeagueByIdResponse LeagueByIdResponse { get; set; }
    bool success;
    private FluentValidationValidator fluentValidationValidator;
    private IJSObjectReference? _module;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var leagueId = Guid.Parse(Id);
            LeagueByIdResponse = await DataLoader.GetOrLoad(
                () => LeagueLocalCache.GetLeagueByIdCache(Id), 
                () => LeagueService.GetLeague(leagueId),
                (l) => LeagueLocalCache.SetLeagueByIdCache(Id, l)
            );

            MapLeagueToModel(LeagueByIdResponse.League);

            PageLoad = true;

        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private void MapLeagueToModel(LeagueModel league)
    {
        model.Id = league.Id;
        model.TotalGamesPerSeason = league.TotalGamesPerSeason == 0 ? null : league.TotalGamesPerSeason;
        model.TotalPlayoffTeams = league.TotalPlayoffTeams == 0 ? null : league.TotalPlayoffTeams;
        model.MinimumTotalTeamPlayers = league.MinimumTotalTeamPlayers == 0 ? null : league.MinimumTotalTeamPlayers;
        model.MaximumTotalTeamPlayers = league.MaximumTotalTeamPlayers == 0 ? null : league.MaximumTotalTeamPlayers;
    }

    private async Task OnSubmit()
    {
        try
        {
            PageLoad = false;

            UpdateLeagueSettingsRequest request = new UpdateLeagueSettingsRequest(
                model.Id, 
                model.TotalGamesPerSeason ?? 0, 
                model.TotalPlayoffTeams ?? 0, 
                model.MinimumTotalTeamPlayers ?? 0, 
                model.MaximumTotalTeamPlayers ?? 0
            );

            await LeagueService.UpdateLeagueSettings(request);

            Snackbar.Add("League Settings has been updated.", MudBlazor.Severity.Success);

            await LeagueLocalCache.DeleteLeaguesCache();
            await LeagueLocalCache.DeleteLeagueByIdCache(Id);
            await LeagueLocalCache.DeleteLeagueBySportCache(LeagueByIdResponse.League.Sport);
            await LeagueLocalCache.DeleteLeagueByNameCache();

            NavManager.NavigateTo("/leagues");
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
        finally
        {
            PageLoad = true;
        }

    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

}
