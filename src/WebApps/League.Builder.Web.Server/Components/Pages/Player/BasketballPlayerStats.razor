@page "/basketballplayerstats/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject IPlayerService PlayerService
@inject IStatsService StatService
@inject ISeasonService SeasonService
@inject IGameService GameService
@inject ITeamService TeamService
@inject ILeagueService LeagueService
@inject IAWSService AWSService
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject ISeasonLocalCacheService SeasonLocalCache
@inject IPlayerLocalCacheService PlayerLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject ILeagueLocalCacheService LeagueLocalCache
@inject IStatsLocalCacheService StatLocalCache
@inject IGameLocalCacheService GameLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService

<AuthorizeView Roles="@String.Concat(Roles.ReadStats, ", ", Roles.ReadSeasons, ", ", Roles.ReadGames, ", ", Roles.ReadTeams)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudContainer Class="pt-12">
                <PlayerHeaderCard Player="PlayerModel"
                                  Team="TeamModel"
                                  Image="@imageFile"
                                  Address="address"
                                  OnContactClick="OpenContactDialogAsync" />
                <MudItem Class="padtop-20">
                    <SeasonSelectorPanel Seasons="SeasonsModel.Seasons"
                                         SelectedSeason="seasonValue"
                                         SelectedSeasonChanged="@((int v) => seasonValue = v)"
                                         OnSearch="GetPlayerStatsBySeason"
                                         Title="@($"{SeasonModel.Season.Year} Stats")" />
                </MudItem>
                <MudItem Class="padtop-20 mb-50">
                    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary" Centered="true" Class="border border-solid" Style="border-color: #000000; padding: 25px;">
                        <MudTabPanel Text="Stats">
                            <MudItem Class="padtop-20">
                                <BasketballStatsTotalsCard Totals="Totals"
                                                           Index="1"
                                                           OnInfoClick="OpenStatDialogAsync" />
                            </MudItem>
                            <MudItem Class="mt-50">
                                <BasketballStatsTotalsCard Totals="Totals"
                                                           Index="2"
                                                           OnInfoClick="OpenStatDialogAsync" />
                            </MudItem>
                            <MudItem Class="padtop-20">
                                <PlayerStatsBasketballTable Rows="PlayerStats" />
                            </MudItem>
                        </MudTabPanel>
                    </MudTabs>
                </MudItem>

            </MudContainer>
        }
        else
        {
            <Loading />
        }

    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set; }
    private bool PageLoad = false;
    private int seasonValue;
    private string seasonPlaceholder = "Season";
    private string imageFile = string.Empty;
    string address = string.Empty;
    private bool expandSearchPanel = false;
    private IJSObjectReference? _module;
    private List<PlayerStatRecord> PlayerStats = new List<PlayerStatRecord>();

    GetPlayerByIdResponse PlayerModel { get; set; }
    GetPlayerBasketballStatsBySeasonResponse StatsModel { get; set; }
    GetSeasonsResponse SeasonsModel { get; set; }
    GetSeasonByYearResponse SeasonModel { get; set; }
    GetGamesByTeamResponse GameModel { get; set; }
    GetTeamByIdResponse TeamModel { get; set; }
    GetLeagueByIdResponse LeagueModel { get; set; }

    BasketballTotalsModel Totals = new();


    protected override async Task OnInitializedAsync()
    {
        try
        {
            int year = DateTime.Now.Year;
            SeasonsModel = await DataLoader.GetOrLoad(
                () => SeasonLocalCache.GetSeasonsCache(),
                () => SeasonService.GetSeasons(),
                (s) => SeasonLocalCache.SetSeasonsCache(s)
            );
            seasonValue = SeasonsModel.Seasons.FirstOrDefault(x => x.Year == year).Year;
            await CreatePlayerStats(year);
            PageLoad = true;

        }
        catch (Exception ex)
        {
            if (KeycloakTokenService.ShouldForceLogout())
            {
                _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
                await _module.InvokeVoidAsync("logout");
            }
            ErrorState.Message = ex.Message;
            NavManager.NavigateTo("/error");
        }

    }

    private async Task GetPlayerStatsBySeason()
    {
        PageLoad = false;
        Totals = new();
        await CreatePlayerStats(seasonValue);
        PageLoad = true;
    }

    private async Task CreatePlayerStats(int year)
    {
        var playerId = Guid.Parse(Id);
        PlayerModel = await DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayerByIdCache(Id),
            () => PlayerService.GetPlayerById(playerId),
            (p) => PlayerLocalCache.SetPlayerByIdCache(p, Id)
        );

        TeamModel = await DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(PlayerModel.Player.TeamId.ToString()),
            () => TeamService.GetTeamById(PlayerModel.Player.TeamId),
            (t) => TeamLocalCache.SetTeamByIdCache(PlayerModel.Player.TeamId.ToString(), t)
        );

        LeagueModel = await DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeagueByIdCache(TeamModel.Team.LeagueId.ToString()),
            () => LeagueService.GetLeague(TeamModel.Team.LeagueId),
            (l) => LeagueLocalCache.SetLeagueByIdCache(TeamModel.Team.LeagueId.ToString(), l)
        );

        SeasonModel = await DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonByYearCache(year),
            () => SeasonService.GetSeasonByYear(year),
            (s) => SeasonLocalCache.SetSeasonByYearCache(year, s)
        );

        StatsModel = await DataLoader.GetOrLoad(
            () => StatLocalCache.GetPlayerBasketballStatsBySeasonCache(Id, SeasonModel.Season.Id.ToString()),
            () => StatService.GetPlayerBasketballStatsBySeason(playerId, SeasonModel.Season.Id),
            (s) => StatLocalCache.SetPlayerBasketballStatsBySeasonCache(Id, SeasonModel.Season.Id.ToString(), s)
        );

        GameModel = await DataLoader.GetOrLoad(
            () => GameLocalCache.GetGamesByTeamCache(PlayerModel.Player.TeamId.ToString()),
            () => GameService.GetGamesByTeam(PlayerModel.Player.TeamId),
            (g) => GameLocalCache.SetGamesByTeamCache(PlayerModel.Player.TeamId.ToString(), g)
        );

        imageFile = await ImageService.GetPlayerImageAsync(LeagueModel.League, TeamModel.Team, PlayerModel.Player);
        address = String.Concat(PlayerModel.Player.PlayerAddress.AddressLine, ", ", PlayerModel.Player.PlayerAddress.State, ", ", PlayerModel.Player.PlayerAddress.ZipCode);


        await BuildRows();
        Calculate(StatsModel.BasketballStats);
    }

    private async Task BuildRows()
    {
        PlayerStats.Clear();
        foreach(var stat in StatsModel.BasketballStats)
        {
            var game = GameModel.Games.FirstOrDefault(g => g.Id == stat.GameId);
            var opposingTeam = game.AwayTeam.Id != PlayerModel.Player.TeamId
            ? game.AwayTeam.TeamName
            : game.HomeTeam.TeamName;

            var team = game.AwayTeam.Id != PlayerModel.Player.TeamId
            ? await TeamService.GetTeamById(game.AwayTeam.Id)
            : await TeamService.GetTeamById(game.HomeTeam.Id);

            var teamImage = await ImageService.GetTeamImageAsync(LeagueModel.League, team.Team);


            PlayerStats.Add(new PlayerStatRecord(opposingTeam, teamImage, stat));
        }
    }

    private void Calculate(IEnumerable<BasketballStatsModel> stats)
    {
        foreach(var s in stats)
        {
            Totals.Points += s.Stats.Points;
            Totals.FieldGoalsMade += s.Stats.FieldGoalsMade;
            Totals.FieldGoalsAttempted += s.Stats.FieldGoalsAttempted;
            Totals.ThreePointersMade += s.Stats.ThreePointersMade;
            Totals.ThreePointersAttempted += s.Stats.ThreePointersAttempted;
            Totals.FreeThrowsMade += s.Stats.FreeThrowsMade;
            Totals.FreeThrowsAttempted += s.Stats.FreeThrowsAttempted;
            Totals.Rebounds += s.Stats.Rebounds;
            Totals.Assists += s.Stats.Assists;
            Totals.Steals += s.Stats.Steals;
            Totals.Blocks += s.Stats.Blocks;
            Totals.Turnovers += s.Stats.Turnovers;
            Totals.Fouls += s.Stats.Fouls;
        }

        Totals.PointsAverage = SafeAvg(Totals.Points, StatsModel.BasketballStats.Count());
        Totals.ReboundsAverage = SafeAvg(Totals.Rebounds, StatsModel.BasketballStats.Count());
        Totals.AssistsAverage = SafeAvg(Totals.Assists, StatsModel.BasketballStats.Count());
        Totals.StealsAverage = SafeAvg(Totals.Steals, StatsModel.BasketballStats.Count());
        Totals.BlocksAverage = SafeAvg(Totals.Blocks, StatsModel.BasketballStats.Count());

        Totals.FieldGoalPercentage = SafePct(Totals.FreeThrowsMade, Totals.FreeThrowsAttempted);
        Totals.ThreePointerPercentage = SafePct(Totals.ThreePointersMade, Totals.ThreePointersAttempted);
        Totals.FreeThrowPercentage = SafePct(Totals.FreeThrowsMade, Totals.FreeThrowsAttempted);
    }

    private decimal SafeAvg(int numerator, int denominator) =>
        denominator == 0 ? 0 : (decimal)numerator / denominator;

    private decimal SafePct(int made, int attempted) =>
        attempted == 0 ? 0 : (decimal)made / attempted * 100;

    private Task OpenContactDialogAsync()
    {
        var parameters = new DialogParameters<PlayerContactInfoMessageBox> { { x => x.Id, PlayerModel.Player.Id } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };

        return DialogService.ShowAsync<PlayerContactInfoMessageBox>("Contact Info", parameters, options);
    }

    private Task OpenStatDialogAsync(string message)
    {
        var parameters = new DialogParameters<StatInfoMessageBox> { { x => x.Message, message } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        return DialogService.ShowAsync<StatInfoMessageBox>("Stat Info", parameters, options);
    }
}
