@page "/updateplayer/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject IPlayerService PlayerService
@inject ITeamService TeamService
@inject ILeagueService LeagueService
@inject ISeasonService SeasonService
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject IHttpContextAccessor HttpContextAccessor
@inject ISnackbar Snackbar
@inject IAWSService AWSService
@inject IValidator<UpdatePlayerModel> UpdatePlayerValidator
@inject IDialogService DialogService
@inject ILeagueLocalCacheService LeagueLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject IPlayerLocalCacheService PlayerLocalCache
@inject ISeasonLocalCacheService SeasonLocalCache
@inject IStatsLocalCacheService StatsLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService

<AuthorizeView Roles="@String.Concat(Roles.UpdatePlayers)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="pt-12">
                <MudPaper Class="border border-solid p-25" Style="border-color: #000000;">
                    <MudText Typo="Typo.h4" Align="Align.Center" Class="font-bold">Update @PlayerByIdResponse.Player.FirstName @PlayerByIdResponse.Player.LastName</MudText>
                </MudPaper>
            </MudItem>
            // Add select option when more leagues are created
            // Add image selection when next version is worked
            <MudItem Class="mt-50 mb-50">
                <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                    <FluentValidationValidator @ref="fluentValidationValidator" />
                    <MudPaper Class="border border-solid p-25" Style="border-color: #000000; width: 100%;">
                        <MudStepper @bind-ActiveIndex="_index" OnPreviewInteraction="@OnStepInteraction" CurrentStepColor="Color.Secondary" CompletedStepColor="Color.Success">
                            <ChildContent>
                                 <MudStep Title="Update Player Contact Information">
                                     <MudGrid Justify="Justify.Center">
                                         <MudItem xs="12" sm="10">
                                             @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.Person, "Player Contact Information")
                                                <MudTextField Required Label="First Name" HelperText="Max. 50 characters"
                                                              @bind-Value="model.FirstName" For="@(() => model.FirstName)" Clearable />
                                                <MudTextField Required Label="Last Name" HelperText="Max. 50 characters"
                                                              @bind-Value="model.LastName" For="@(() => model.LastName)" Clearable />
                                                <MudSelect Required Class="mt-3" Label="Team" @bind-Value="model.TeamId">
                                                    @TeamOptions
                                                </MudSelect>
                                                 </div>)
                                         </MudItem>
                                     </MudGrid>
                                 </MudStep>
                                <MudStep Title="Update Player Details">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                @StepHeader(Icons.Material.Filled.Info, "Player Details")
                                                <MudTextField Required Label="Email Address" Class="mt-3"
                                                              @bind-Value="model.EmailAddress" For="@(() => model.EmailAddress)" Clearable />
                                                <MudTextField Mask="@phoneNumberMask" Required Label="Phone Number" Class="mt-3"
                                                              @bind-Value="model.PhoneNumber" For="@(() => model.PhoneNumber)" Clearable />
                                                <MudDatePicker Required Class="mt-3" Label="Birth Date" Editable @bind-Date="model.BirthDate" />
                                                <MudSelect Required @bind-Value="model.Height" Class="mt-3" Placeholder="@heightPlaceholder" Label="@heightPlaceholder">
                                                    @HeightOptions
                                                </MudSelect>
                                                <MudTextField Required Label="Weight" Class="mt-3"
                                                              @bind-Value="model.Weight" For="@(() => model.Weight)" Clearable />
                                                <MudSelect Required Class="mt-3" Label="Number" @bind-Value="model.Number">
                                                    @JerseyOptions
                                                </MudSelect>
                                                <MudSelect Required Class="mt-3" Label="Position" @bind-Value="model.Position">
                                                    @PositionOptions
                                                </MudSelect>
                                                <MudTextField Label="Description" Class="mt-3"
                                                              @bind-Value="model.Description" For="@(() => model.Description)" Clearable />
                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Update Player Address">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                    @StepHeader(Icons.Material.Filled.House, "Player Address")
                                                    <MudTextField Required Label="Address Line" Class="mt-3"
                                                                  @bind-Value="model.AddressLine" For="@(() => model.AddressLine)" Clearable />
                                                    <MudTextField Required Label="City" Class="mt-3"
                                                                  @bind-Value="model.City" For="@(() => model.City)" Clearable />
                                                    <MudSelect Required Class="mt-3" Label="State" @bind-Value="model.State">
                                                        @StateOptions
                                                    </MudSelect>
                                                    <MudSelect Required Class="mt-3" Label="Country" @bind-Value="model.Country">
                                                        @CountryOptions
                                                    </MudSelect>
                                                    <MudTextField Required="true" Label="Zip Code" Class="mt-3"
                                                                  @bind-Value="model.ZipCode" For="@(() => model.ZipCode)" Clearable />
                                                </div>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                                <MudStep Title="Review">
                                    <MudGrid Justify="Justify.Center">
                                        <MudItem xs="12" sm="10">
                                            @Card(@<div>
                                                    @StepHeader(Icons.Material.Filled.RemoveRedEye, "Review")
                                                    <MudTextField Required ReadOnly Label="First Name" HelperText="Max. 50 characters"
                                                                  @bind-Value="model.FirstName" For="@(() => model.FirstName)" />
                                                    <MudTextField Required ReadOnly Label="Last Name" HelperText="Max. 50 characters"
                                                                  @bind-Value="model.LastName" For="@(() => model.LastName)" />
                                                    <MudSelect Required Class="mt-3" Label="Team" @bind-Value="model.TeamId">
                                                        @TeamOptions
                                                    </MudSelect>
                                                    <MudTextField Required ReadOnly Label="Email Address" Class="mt-3"
                                                                    @bind-Value="model.EmailAddress" For="@(() => model.EmailAddress)" />
                                                    <MudTextField Mask="@phoneNumberMask" Required ReadOnly Label="Phone Number" Class="mt-3"
                                                                    @bind-Value="model.PhoneNumber" For="@(() => model.PhoneNumber)" />
                                                    <MudDatePicker Required ReadOnly Class="mt-3" Label="Birth Date" Editable @bind-Date="model.BirthDate" />
                                                    <MudSelect Required @bind-Value="model.Height" Class="mt-3" Placeholder="@heightPlaceholder" Label="@heightPlaceholder" ReadOnly>
                                                        @HeightOptions
                                                    </MudSelect>
                                                    <MudTextField Required ReadOnly Label="Weight" Class="mt-3"
                                                                    @bind-Value="model.Weight" For="@(() => model.Weight)" />
                                                    <MudSelect Required ReadOnly Class="mt-3" Label="Number" @bind-Value="model.Number">
                                                        @JerseyOptions
                                                    </MudSelect>
                                                    <MudSelect Required ReadOnly Class="mt-3" Label="Position" @bind-Value="model.Position">
                                                        @PositionOptions
                                                    </MudSelect>
                                                    <MudTextField ReadOnly Label="Description" Class="mt-3"
                                                                    @bind-Value="model.Description" For="@(() => model.Description)" />
                                                    <MudTextField Required ReadOnly Label="Address Line" Class="mt-3"
                                                                    @bind-Value="model.AddressLine" For="@(() => model.AddressLine)" />
                                                    <MudTextField Required ReadOnly Label="City" Class="mt-3"
                                                                    @bind-Value="model.City" For="@(() => model.City)" />
                                                    <MudSelect Required ReadOnly Class="mt-3" Label="State" @bind-Value="model.State">
                                                        @StateOptions
                                                    </MudSelect>
                                                    <MudSelect Required ReadOnly Class="mt-3" Label="Country" @bind-Value="model.Country">
                                                        @CountryOptions
                                                    </MudSelect>
                                                    <MudTextField Required ReadOnly Label="Zip Code" Class="mt-3"
                                                                    @bind-Value="model.ZipCode" For="@(() => model.ZipCode)" />
                                                    <MudItem Class="padtop-20">
                                                        <MudStack Row="true">
                                                            <MudFileUpload @ref="@_fileUpload"
                                                                           T="IBrowserFile"
                                                                           For="@(() => model.File)"
                                                                           @bind-Files="model.File" CustomContent="UploadButton">
                                                            </MudFileUpload>
                                                        </MudStack>
                                                    </MudItem>
                                                </div>,
                                                @<MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" FullWidth="true">Update</MudButton>)
                                        </MudItem>
                                    </MudGrid>
                                </MudStep>
                            </ChildContent>
                            <ActionContent Context="stepper">
                                <MudIconButton OnClick="@(() => stepper.PreviousStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowBack"
                                               Color="Color.Primary"
                                               Disabled="_index == 0">
                                </MudIconButton>
                                <MudSpacer />
                                <MudIconButton OnClick="@(() => stepper.NextStepAsync())"
                                               Icon="@Icons.Material.Filled.ArrowForward"
                                               Color="Color.Primary"
                                               Disabled="_index == 3">
                                </MudIconButton>
                            </ActionContent>
                        </MudStepper>
                    </MudPaper>
                </EditForm>
            </MudItem>

        }
        else
        {
            <Loading />
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set; }

    private bool PageLoad = false;
    bool success;
    string sport;
    private bool canProceed;
    bool uploadFile;

    private int _index;
    private int year;

    private List<string> states;
    private List<string> countries;
    private List<int> jerseyNumbers;
    private string heightPlaceholder = "Height";
    private List<string> errors = new();

    UpdatePlayerModel model = new();
    private IJSObjectReference? _module;

    private MudFileUpload<IBrowserFile> _fileUpload;
    private FluentValidationValidator fluentValidationValidator;
    public PatternMask phoneNumberMask = new PatternMask("(000)-000-0000");

    private GetPlayerByIdResponse PlayerByIdResponse { get; set; }
    private GetTeamsResponse TeamsResponse { get; set; }
    private GetTeamByIdResponse TeamById { get; set; }
    private GetLeagueByIdResponse LeagueById { get; set; }
    private GetSeasonByYearResponse SeasonByYearResponse { get; set; }
    private GetPlayersByTeamResponse PlayersByTeamResponse { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAllAsync();
            MapModel();
            RemoveTakenJerseyNumbers();
            PageLoad = true;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task LoadAllAsync()
    {
        year = DateTime.Now.Year;
        var playerId = Guid.Parse(Id);

        PlayerByIdResponse = await LoadPlayerAsync(playerId);
        TeamsResponse = await LoadTeamsAsync();
        TeamById = await LoadTeamByIdAsync(PlayerByIdResponse.Player.TeamId);
        PlayersByTeamResponse = await LoadPlayersByTeamAsync(TeamById.Team.Id);
        LeagueById = await LoadLeagueAsync(TeamById.Team.LeagueId);
        SeasonByYearResponse = await LoadSeasonAsync(year);

        sport = LeagueById.League.Sport;
        states = Constants.States();
        countries = Constants.Countries();
        jerseyNumbers = Constants.JerseyNumbers();

    }

    private void MapModel()
    {
        var p = PlayerByIdResponse.Player;

        model.Id = p.Id;
        model.TeamId = p.TeamId;
        model.FirstName = p.FirstName;
        model.LastName = p.LastName;
        model.AddressLine = p.PlayerAddress.AddressLine;
        model.City = p.PlayerAddress.City;
        model.State = p.PlayerAddress.State;
        model.Country = p.PlayerAddress.Country;
        model.ZipCode = p.PlayerAddress.ZipCode;
        model.EmailAddress = p.PlayerDetail.EmailAddress;
        model.PhoneNumber = p.PlayerDetail.PhoneNumber;
        model.BirthDate = p.PlayerDetail.BirthDate;
        model.Height = p.PlayerDetail.Height;
        model.Weight = p.PlayerDetail.Weight;
        model.Number = p.PlayerDetail.Number;
        model.Position = p.PlayerDetail.Position;
        model.Description = p.Description;
        model.ImageFile = p.ImageFile;
        model.PlayerStatus = p.PlayerStatus;

    }

    private Task<GetPlayerByIdResponse> LoadPlayerAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayerByIdCache(Id),
            () => PlayerService.GetPlayerById(id),
            (p) => PlayerLocalCache.SetPlayerByIdCache(p, Id)
        );

    private Task<GetTeamsResponse> LoadTeamsAsync() =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamsCache(),
            () => TeamService.GetTeams(0, 1000),
            (t) => TeamLocalCache.SetTeamsCache(t)
        );

    private Task<GetTeamByIdResponse> LoadTeamByIdAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(id.ToString()),
            () => TeamService.GetTeamById(id),
            (t) => TeamLocalCache.SetTeamByIdCache(id.ToString(), t)
        );

    private Task<GetPlayersByTeamResponse> LoadPlayersByTeamAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayersByTeamCache(id.ToString()),
            () => PlayerService.GetPlayersByTeam(id),
            (p) => PlayerLocalCache.SetPlayersByTeamCache(id.ToString(), p)
        );

    private Task<GetLeagueByIdResponse> LoadLeagueAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeagueByIdCache(id.ToString()),
            () => LeagueService.GetLeague(id),
            (l) => LeagueLocalCache.SetLeagueByIdCache(id.ToString(), l)
        );

    private Task<GetSeasonByYearResponse> LoadSeasonAsync(int year) =>
        DataLoader.GetOrLoad(
            () => SeasonLocalCache.GetSeasonByYearCache(year),
            () => SeasonService.GetSeasonByYear(year),
            (s) => SeasonLocalCache.SetSeasonByYearCache(year, s)
        );

    private async Task OnValidSubmit(EditContext context)
    {
        try
        {
            await HandleImageUpdateAsync();

            await UpdatePlayerRecordAsync();
            await ClearCachesAsync();
            Snackbar.Add("Player was updated.", MudBlazor.Severity.Success);
            NavManager.NavigateTo($"/playersbyteam/{model.TeamId.ToString()}");
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task HandleImageUpdateAsync()
    {
        var oldFirst = PlayerByIdResponse.Player.FirstName;
        var oldLast = PlayerByIdResponse.Player.LastName;

        if (oldFirst != model.FirstName || oldLast != model.LastName)
        {
            if (model.File is null)
            {
                await ImageService.CopyPlayerImageForUpdateAsync(LeagueById.League, TeamById.Team, PlayerByIdResponse.Player, model);
            }
            else
            {
                model.ImageFile = model.File.Name;
                await ImageService.CopyPlayerImageForUpdateAsync(LeagueById.League, TeamById.Team, PlayerByIdResponse.Player, model);
            }
        }
        else if(model.File is not null)
        {
            model.ImageFile = model.File.Name;
            await ImageService.UploadUpdatedPlayerImageAsync(LeagueById.League, TeamById.Team, model);
        }
    }

    private async Task UpdatePlayerRecordAsync()
    {
        Models.Player.AddressModel address = new Models.Player.AddressModel(model.AddressLine, model.City, model.Country, model.State, model.ZipCode);
        Models.Player.PlayerDetailModel playerDetail = new Models.Player.PlayerDetailModel(model.EmailAddress, model.PhoneNumber, model.BirthDate.Value, model.Height, (int)model.Weight, model.Position, model.Number);
        UpdatePlayerRequest request = new UpdatePlayerRequest(new UpdatePlayerRecord(model.Id, model.TeamId, model.FirstName, model.LastName, address, playerDetail, model.Description, model.ImageFile, (int)model.PlayerStatus));
        await PlayerService.UpdatePlayer(request);
    }

    private async Task ClearCachesAsync()
    {
        await PlayerLocalCache.DeletePlayersCache();
        await PlayerLocalCache.DeletePlayerByIdCache(model.Id.ToString());
        await PlayerLocalCache.DeletePlayersByFirstNameCache();
        await PlayerLocalCache.DeletePlayersByLastNameCache();
        await PlayerLocalCache.DeletePlayersByPositionCache();
        await PlayerLocalCache.DeletePlayersByBirthDateCache();
        await PlayerLocalCache.DeletePlayersBeforeBirthDateCache();
        await PlayerLocalCache.DeletePlayersAfterBirthDateCache();
        await PlayerLocalCache.DeletePlayersByTeamCache(model.TeamId.ToString());
        await ClearStatsCachesAsync();
    }

    private async Task ClearStatsCachesAsync()
    {
        var leagueId = LeagueById.League.Id.ToString();
        var seasonId = SeasonByYearResponse.Season.Id.ToString();
        var teamId = model.TeamId.ToString();
        var playerId = model.Id.ToString();

        switch (LeagueById.League.Sport)
        {
            case SportName.BASEBALL:
                await StatsLocalCache.DeleteLeagueBaseballStatsBySeasonCache(leagueId, seasonId);
                await StatsLocalCache.DeleteBaseballStatsByTeamCache(teamId);
                await StatsLocalCache.DeleteBaseballStatsByPlayerCache(playerId);
                await StatsLocalCache.DeletePlayerBaseballStatsBySeasonCache(playerId, seasonId);
                break;
            case SportName.BASKETBALL:
                await StatsLocalCache.DeleteLeagueBasketballStatsBySeasonCache(leagueId, seasonId);
                await StatsLocalCache.DeleteBasketballStatsByTeamCache(teamId);
                await StatsLocalCache.DeleteBasketballStatsByPlayerCache(playerId);
                await StatsLocalCache.DeletePlayerBasketballStatsBySeasonCache(playerId, seasonId);
                break;
            case SportName.FOOTBALL:
                await StatsLocalCache.DeleteLeagueFootballStatsBySeasonCache(leagueId, seasonId);
                await StatsLocalCache.DeleteFootballStatsByTeamCache(teamId);
                await StatsLocalCache.DeleteFootballStatsByPlayerCache(playerId);
                await StatsLocalCache.DeletePlayerFootballStatsBySeasonCache(playerId, seasonId);
                break;
        }
    }

    private async Task OnStepInteraction(StepperInteractionEventArgs args)
    {
        canProceed = false;
        await ValidateCurrentStep();
        if (args.Action == StepAction.Complete && !canProceed)
        {
            await OpenErrorDialogAsync();
            args.Cancel = true;
        }
    }

    private async Task ValidateCurrentStep()
    {
        errors.Clear();

        var props = _index switch
        {
            0 => new[] { nameof(UpdatePlayerModel.FirstName), nameof(UpdatePlayerModel.LastName) },
            1 => new[] { nameof(UpdatePlayerModel.EmailAddress), nameof(UpdatePlayerModel.PhoneNumber),
                         nameof(UpdatePlayerModel.BirthDate), nameof(UpdatePlayerModel.Height),
                         nameof(UpdatePlayerModel.Weight), nameof(UpdatePlayerModel.Number),
                         nameof(UpdatePlayerModel.Position) },
            2 => new[] { nameof(UpdatePlayerModel.AddressLine), nameof(UpdatePlayerModel.State),
                         nameof(UpdatePlayerModel.Country), nameof(UpdatePlayerModel.ZipCode) },
            _ => Array.Empty<string>()
        };

        var result = await UpdatePlayerValidator.ValidateAsync(model, opts => opts.IncludeProperties(props));
        canProceed = result.IsValid;

        foreach (var error in result.Errors)
            errors.Add($"{error.ErrorMessage}");
    }

    private Task OpenErrorDialogAsync()
    {
        var parameters = new DialogParameters<ErrorMessageBox> { { x => x.Errors, errors } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        return DialogService.ShowAsync<ErrorMessageBox>("Errors", parameters, options);
    }

    private void RemoveTakenJerseyNumbers()
    {
        foreach (var player in PlayersByTeamResponse.Players)
            if(player.Id != model.Id)
                jerseyNumbers.Remove(player.PlayerDetail.Number);
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }

    private RenderFragment Card(RenderFragment content, RenderFragment actions = null) => @<MudCard Class="border border-solid border-black">
            <MudCardContent>
                @content
            </MudCardContent>
        @if (actions is not null)
        {
                <MudCardActions>
                    @actions
                </MudCardActions>
        }
    </MudCard>;

    private Func<string, string, RenderFragment> StepHeader = (string icon, string title) => @<MudStack Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Row="true">
            <MudIcon Icon="@icon" Color="Color.Secondary" Size="Size.Medium" />
            <MudText Typo="Typo.h6" Class="font-bold">@title</MudText>
        </MudStack>;

    private RenderFragment TeamOptions => __builder =>
    {
        foreach (var teams in TeamsResponse.Teams.Data.Where(l => l.Id == model.TeamId))
        {
            <MudSelectItem Value="@teams.Id">@teams.TeamName</MudSelectItem>
            ;
        }
    };

    private RenderFragment HeightOptions => __builder =>
    {
        foreach (var height in Constants.Height())
        {
            <MudSelectItem Value="@height.Key">@height.Value</MudSelectItem>
            ;
        }
    };

    private RenderFragment JerseyOptions => __builder =>
    {
        foreach (var jerseyNumber in jerseyNumbers)
        {
            <MudSelectItem Value="@jerseyNumber">@jerseyNumber</MudSelectItem>
            ;
        }
    };

    private RenderFragment PositionOptions => __builder =>
    {
        foreach (var position in Constants.PositionsBySport(sport))
        {
            <MudSelectItem Value="@position">@position</MudSelectItem>
            ;
        }
    };

    private RenderFragment StateOptions => __builder =>
    {
        foreach (var state in states)
        {
            <MudSelectItem Value="@state">@state</MudSelectItem>
            ;
        }
    };

    private RenderFragment CountryOptions => __builder =>
    {
        foreach (var country in countries)
        {
            <MudSelectItem Value="@country">@country</MudSelectItem>
            ;
        }
    };

    private RenderFragment<MudFileUpload<IBrowserFile>> UploadButton =>
    (fileUpload) => @<MudButton Variant="Variant.Filled"
                                Color="Color.Primary"
                                StartIcon="@Icons.Material.Filled.CloudUpload"
                                OnClick="@(() => fileUpload.OpenFilePickerAsync())">
                    Player Image
                    </MudButton>;
}
