@using League.Builder.Web.Server.Services.Cache
@inject IPlayerService PlayerService
@inject ITeamService TeamService
@inject NavigationManager NavManager;
@inject IPlayerLocalCacheService PlayerLocalCache
@inject ITeamLocalCacheService TeamLocalCache

@if (DataLoad)
{
    <MudDialog>
        <TitleContent>
            <MudText Align="Align.Center" Typo="Typo.h4" Class="font-bold" Style="@($"color: {TeamModel.Team.TeamColor} !important")">Contact Info</MudText>
        </TitleContent>
        <DialogContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center">
                <MudIconButton Href="@MailUrl" Icon="@Icons.Material.Filled.Email" Style="@($"color: {TeamModel.Team.TeamColor} !important")" />
                <MudText Typo="Typo.h6">@PlayerModel.Player.PlayerDetail.EmailAddress</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center">
                <MudIcon Icon="@Icons.Material.Filled.Phone" Style="@($"color: {TeamModel.Team.TeamColor} !important")" />
                <MudText Typo="Typo.h6">@PlayerModel.Player.PlayerDetail.PhoneNumber</MudText>
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton Style="@($"background-color: {TeamModel.Team.TeamColor} !important")" OnClick="Ok">Ok</MudButton>
        </DialogActions>
    </MudDialog>
    
}

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Guid Id { get; set; }
    private bool DataLoad;
    private string MailUrl = string.Empty;

    GetPlayerByIdResponse PlayerModel { get; set; }
    GetTeamByIdResponse TeamModel { get; set; }

    protected override async Task OnInitializedAsync()
    {
        PlayerModel = await DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayerByIdCache(Id.ToString()),
            () => PlayerService.GetPlayerById(Id),
            (p) => PlayerLocalCache.SetPlayerByIdCache(p, Id.ToString())
        );
        TeamModel = await DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(PlayerModel.Player.TeamId.ToString()),
            () => TeamService.GetTeamById(PlayerModel.Player.TeamId),
            (t) => TeamLocalCache.SetTeamByIdCache(PlayerModel.Player.TeamId.ToString(), t)
        );
        MailUrl = $"mailto:{PlayerModel.Player.PlayerDetail.EmailAddress}?subject=MessageTitle&amp;body=Message Content";
        DataLoad = true;
    }

    private void Ok() => MudDialog.Cancel();
}
