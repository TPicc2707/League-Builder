@page "/players"
@using League.Builder.Web.Server.Services.Cache
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject ILeagueService LeagueService
@inject ITeamService TeamService
@inject IPlayerService PlayerService
@inject IAWSService AWSService
@inject IHttpContextAccessor HttpContextAccessor
@inject ILeagueLocalCacheService LeagueLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject IPlayerLocalCacheService PlayerLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService
@inject AuthenticationStateProvider AuthenticationStateProvider

<AuthorizeView Roles="@Roles.ReadPlayers" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="pt-12">
                <MudExpansionPanels>
                    <MudExpansionPanel Class="border border-solid" Style="border-color: #000000" Expanded="expandSearchPanel">
                        <TitleContent>
                            <MudText Typo="Typo.h5" Align="Align.Center" Class="font-bold">Search Players</MudText>
                        </TitleContent>
                        <ChildContent>
                            <MudItem>
                                <MudTabs Elevation="2" Centered="true" Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary" Class="pa-6 border border-solid" Style="border-color: #000000">
                                    <MudTabPanel Text="Search All">
                                        <MudItem Class="padtop-20">
                                            <MudButton OnClick="@(()=> ExecuteSearch(SearchAllInternal))"
                                                      Variant="Variant.Filled" 
                                                      Color="Color.Primary" 
                                                      Class="ml-auto" 
                                                      FullWidth="true">
                                                      Search All
                                            </MudButton>
                                        </MudItem>
                                    </MudTabPanel>
                                    <MudTabPanel Text="First Name">
                                        <MudStack Row="true" Class="padtop-20">
                                            <MudItem xs="9">
                                                <MudTextField @bind-Value="firstName" Placeholder="First Name" />
                                            </MudItem>
                                            <MudItem xs="3">
                                                <MudButton Disabled="@(firstName == string.Empty)"
                                                           OnClick="@(()=> ExecuteSearch(SearchByFirstNameInternal))"
                                                           Variant="Variant.Filled" 
                                                           Color="Color.Primary" 
                                                           Class="ml-auto" 
                                                           Style="width: 200px;">
                                                           Search
                                                </MudButton>
                                            </MudItem>
                                        </MudStack>
                                    </MudTabPanel>
                                    <MudTabPanel Text="Last Name">
                                        <MudStack Row="true" Class="padtop-20">
                                            <MudItem xs="9">
                                                <MudTextField @bind-Value="lastName" Placeholder="Last Name" />
                                            </MudItem>
                                            <MudItem xs="3">
                                                <MudButton Disabled="@(lastName == string.Empty)" 
                                                           OnClick="@(()=> ExecuteSearch(SearchByLastNameInternal))"
                                                           Variant="Variant.Filled" 
                                                           Color="Color.Primary" 
                                                           Class="ml-auto" 
                                                           Style="width: 200px;">
                                                           Search
                                                </MudButton>
                                            </MudItem>
                                        </MudStack>
                                    </MudTabPanel>
                                    <MudTabPanel Text="Position">
                                        <MudStack Row="true" Class="padtop-20">
                                            <MudItem xs="4">
                                                <MudSelect @bind-Value="sport" Label="Sport">
                                                    @foreach (var sport in Constants.Sports())
                                                    {
                                                        <MudSelectItem Value="@sport">@sport</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="4">
                                                <MudSelect @bind-Value="position" Label="Position" Disabled="@(sport == string.Empty)">
                                                    @foreach (var position in Constants.PositionsBySport(sport))
                                                    {
                                                        <MudSelectItem Value="@position">@position</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="4" Style="align-content: center">
                                                <MudButton Disabled="@(position == string.Empty)"
                                                           OnClick="@(()=> ExecuteSearch(SearchByPositionInternal))"
                                                           Variant="Variant.Filled" 
                                                           Color="Color.Primary" 
                                                           Class="ml-auto" 
                                                           Style="width: 200px;">
                                                           Search
                                                </MudButton>
                                            </MudItem>
                                        </MudStack>
                                    </MudTabPanel>
                                    <MudTabPanel Text="Birth Date">
                                        <MudStack Row="true" Class="padtop-20">
                                            <MudItem xs="4">
                                                <MudSelect @bind-Value="_when" Label="When">
                                                    @foreach (var when in Constants.When())
                                                    {
                                                        <MudSelectItem Value="when">@when</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="4">
                                                <MudDatePicker Label="Birth Date" Disabled="@(_when == string.Empty)" Editable="true" @bind-Date="birthdate" />
                                            </MudItem>
                                            <MudItem xs="4" Style="align-content: center">
                                                <MudButton Disabled="@(birthdate is null)"
                                                           OnClick="@(()=> ExecuteSearch(SearchBirthdateInternal))"
                                                           Variant="Variant.Filled" 
                                                           Color="Color.Primary" 
                                                           Class="ml-auto" 
                                                           Style="width: 200px;">
                                                           Search
                                                </MudButton>
                                            </MudItem>
                                        </MudStack>
                                    </MudTabPanel>
                                </MudTabs>
                            </MudItem>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            @if (Model != null)
            {
                <MudItem Class="py-6">
                    <MudExpansionPanels>
                        <MudExpansionPanel Class="border border-solid" Style="border-color: #000000" Expanded="true">
                            <TitleContent>
                                <MudText Typo="Typo.h5" Align="Align.Center" Class="font-bold">Results</MudText>
                            </TitleContent>
                            <ChildContent>
                                <MudItem>
                                    <MudTable Items="@Model" Hover="true" SortLabel="Sort By" Class="border border-solid" Style="border-color: #000000" RowsPerPage="25">
                                        <HeaderContent>
                                            <MudTh Class="mud-theme-primary font-bold"></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerModel x) => x.FirstName">First Name</MudTableSortLabel></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerModel x) => x.LastName">Last Name</MudTableSortLabel></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"><MudTableSortLabel SortBy="(PlayerModel x) => x.TeamName">Team</MudTableSortLabel></MudTh>
                                            <MudTh Class="mud-theme-primary font-bold">Position</MudTh>
                                            <MudTh Class="mud-theme-primary font-bold">Location</MudTh>
                                            <MudTh Class="mud-theme-primary font-bold"></MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="">
                                                <PlayerAvatar Image="@context.Image" />
                                            </MudTd>
                                            <MudTd DataLabel="First Name">
                                                @if (CanReadStats)
                                                {
                                                    <MudTooltip Text="Player Details" Color="Color.Secondary">
                                                        @if (context.Sport == SportName.BASEBALL)
                                                        {
                                                            <MudLink Color="Color.Tertiary" Href="@($"/baseballplayerstats/{context.Id}")">@context.FirstName</MudLink>
                                                        }
                                                        @if (context.Sport == SportName.BASKETBALL)
                                                        {
                                                            <MudLink Color="Color.Tertiary" Href="@($"/basketballplayerstats/{context.Id}")">@context.FirstName</MudLink>
                                                        }
                                                        @if (context.Sport == SportName.FOOTBALL)
                                                        {
                                                            <MudLink Color="Color.Tertiary" Href="@($"/footballplayerstats/{context.Id}")">@context.FirstName</MudLink>
                                                        }
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    @context.FirstName
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Last Name">
                                                @if (CanReadStats)
                                                {
                                                    <MudTooltip Text="Player Details" Color="Color.Secondary">
                                                        @if (context.Sport == SportName.BASEBALL)
                                                        {
                                                            <MudLink Color="Color.Tertiary" Href="@($"/baseballplayerstats/{context.Id}")">@context.LastName</MudLink>
                                                        }
                                                        @if (context.Sport == SportName.BASKETBALL)
                                                        {
                                                            <MudLink Color="Color.Tertiary" Href="@($"/baseballplayerstats/{context.Id}")">@context.LastName</MudLink>
                                                        }
                                                        @if (context.Sport == SportName.FOOTBALL)
                                                        {
                                                            <MudLink Color="Color.Tertiary" Href="@($"/baseballplayerstats/{context.Id}")">@context.LastName</MudLink>
                                                        }
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    @context.LastName
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Team">@context.TeamName</MudTd>
                                            <MudTd DataLabel="Position">@context.PlayerDetail.Position</MudTd>
                                            <MudTd DataLabel="Location">@context.PlayerAddress.City, @context.PlayerAddress.State</MudTd>
                                            <MudTd DataLabel="Links">
                                                @if (CanUpdatePlayers)
                                                {
                                                    <MudTooltip Text="Update" Color="Color.Secondary">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Update" Color="Color.Tertiary" Edge="Edge.Start" Href="@String.Concat("/updateplayer/", context.Id)" />
                                                    </MudTooltip>
                                                }
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <MudTablePager />
                                        </PagerContent>
                                    </MudTable>
                                </MudItem>
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudItem>
            }
            @if (isSearchLoading)
            {
                <Loading />
            }

        }
        else
        {
            <Loading />
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>

@code {
    private string firstName = string.Empty;
    private string prevFirstName = string.Empty;
    private string lastName  = string.Empty;
    private string prevLastName = string.Empty;
    private string sport = string.Empty;
    private string position = string.Empty;
    private string prevPosition = string.Empty;
    private string _when = string.Empty;
    private DateTime? birthdate;
    private DateTime? prevBirthdate;
    private bool expandSearchPanel = true;
    private bool isSearchLoading = false;
    private bool PageLoad = false;
    private IJSObjectReference? _module;
    private List<PlayerModel> Model { get; set; }
    private GetLeaguesResponse LeaguesResponse { get; set; }
    private GetPlayersResponse PlayersResponse { get; set; }
    private GetPlayersByFirstNameResponse PlayersByFirstNameResponse { get; set; }
    private GetPlayersByLastNameResponse PlayersbyLastNameResponse { get; set; }
    private GetPlayersByPositionResponse PlayersByPositionResponse { get; set; }
    private GetPlayersByBirthDateResponse PlayersByBirthdateResponse { get; set; }
    private GetPlayersBeforeBirthDateResponse PlayersBeforeBirthDateResponse { get; set; }
    private GetPlayersAfterBirthDateResponse PlayersAfterBirthDateResponse { get; set; }
    private GetTeamsResponse TeamsResponse { get; set; }
    private bool CanReadStats;
    private bool CanUpdatePlayers;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            TeamsResponse = await DataLoader.GetOrLoad(
                () => TeamLocalCache.GetTeamsCache(),
                () => TeamService.GetTeams(0, 1000),
                (t) => TeamLocalCache.SetTeamsCache(t)
            );

            LeaguesResponse = await DataLoader.GetOrLoad(
                () => LeagueLocalCache.GetLeaguesCache(),
                () => LeagueService.GetLeagues(),
                (l) => LeagueLocalCache.SetLeaguesCache(l)
            );

            CanReadStats = user.IsInRole(Roles.ReadStats);
            CanUpdatePlayers = user.IsInRole(Roles.UpdatePlayers);

            PageLoad = true;

        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task FinishSearchAsync(IEnumerable<PlayerModel> players)
    {
        Model = players.ToList();
        await GetImageAsync();    
    }

    private async Task ExecuteSearch(Func<Task> searchFunc)
    {
        try
        {
            isSearchLoading = true;
            await searchFunc();
            expandSearchPanel = false;
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
        finally
        {
            isSearchLoading = false;
        }
    }

    private async Task SearchAllInternal()
    {
        var response = await DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayersCache(),
            () => PlayerService.GetPlayers(0, 1000),
            (p) => PlayerLocalCache.SetPlayersCache(p)
        );
        Model = response.Players.Data.ToList();
        await GetImageAsync();
    }

    private async Task SearchByFirstNameInternal()
    {
        GetPlayersByFirstNameResponse response;
        if(prevFirstName == firstName)
        {
            response = await DataLoader.GetOrLoad(
                () => PlayerLocalCache.GetPlayersByFirstNameCache(),
                () => PlayerService.GetPlayersByFirstName(firstName),
                (p) => PlayerLocalCache.SetPlayersByFirstNameCache(p)
            );
        }
        else
        {
            response = await PlayerService.GetPlayersByFirstName(firstName);
            await PlayerLocalCache.SetPlayersByFirstNameCache(response);
            prevFirstName = firstName;
        }

        await FinishSearchAsync(response.Players);
    }

    private async Task SearchByLastNameInternal()
    {
        GetPlayersByLastNameResponse response;
        if (prevLastName == lastName)
        {
            response = await DataLoader.GetOrLoad(
                () => PlayerLocalCache.GetPlayersByLastNameCache(),
                () => PlayerService.GetPlayersByLastName(lastName),
                (p) => PlayerLocalCache.SetPlayersByLastNameCache(p)
            );
        }
        else
        {
            response = await PlayerService.GetPlayersByLastName(lastName);
            await PlayerLocalCache.SetPlayersByLastNameCache(response);
            prevLastName = lastName;
        }

        await FinishSearchAsync(response.Players);
    }

    private async Task SearchByPositionInternal()
    {
        GetPlayersByPositionResponse response;
        if(prevPosition == position)
        {
            response = await DataLoader.GetOrLoad(
                () => PlayerLocalCache.GetPlayersByPositionCache(),
                () => PlayerService.GetPlayersByPosition(position),
                (p) => PlayerLocalCache.SetPlayersByPositionCache(p)
            );
        }
        else
        {
            response = await PlayerService.GetPlayersByPosition(position);
            await PlayerLocalCache.SetPlayersByPositionCache(response);
            prevPosition = position;

        }
        await FinishSearchAsync(response.Players);
    }

    private async Task SearchBirthdateInternal()
    {
        string date = FormatDate(birthdate);
        string prevDate = FormatDate(prevBirthdate);

        bool refresh = prevDate != date;

        if (_when == "By")
        {
            GetPlayersByBirthDateResponse response;
            if(prevBirthdate == birthdate)
            {
                response = await DataLoader.GetOrLoad(
                    () => PlayerLocalCache.GetPlayersByBirthDateCache(),
                    () => PlayerService.GetPlayersByBirthDate(date),
                    (p) => PlayerLocalCache.SetPlayersByBirthDateCache(p)
                );
            }
            else
            {
                response = await PlayerService.GetPlayersByBirthDate(date);
                await PlayerLocalCache.SetPlayersByBirthDateCache(response);
                prevBirthdate = birthdate;
            }

            await FinishSearchAsync(response.Players);

        }
        if (_when == "Before")
        {
            GetPlayersBeforeBirthDateResponse response;
            if(prevBirthdate == birthdate)
            {
                response = await DataLoader.GetOrLoad(
                    () => PlayerLocalCache.GetPlayersBeforeBirthDateCache(),
                    () => PlayerService.GetPlayersBeforeBirthDate(date),
                    (p) => PlayerLocalCache.SetPlayersBeforeBirthDateCache(p)
                );
            }
            else
            {
                response = await PlayerService.GetPlayersBeforeBirthDate(date);
                await PlayerLocalCache.SetPlayersBeforeBirthDateCache(response);
                prevBirthdate = birthdate;
            }

            await FinishSearchAsync(response.Players);
        }
        if (_when == "After")
        {
            GetPlayersAfterBirthDateResponse response;
            if(prevBirthdate == birthdate)
            {
                response = await DataLoader.GetOrLoad(
                    () => PlayerLocalCache.GetPlayersAfterBirthDateCache(),
                    () => PlayerService.GetPlayersAfterBirthDate(date),
                    (p) => PlayerLocalCache.SetPlayersAfterBirthDateCache(p)
                );
            }
            else
            {
                response = await PlayerService.GetPlayersAfterBirthDate(date);
                await PlayerLocalCache.SetPlayersAfterBirthDateCache(response);
                prevBirthdate = birthdate;
            }

            await FinishSearchAsync(response.Players);

        }
    }

    private static string FormatDate(DateTime? date) =>
        date?.ToString("yyyy-MM-dd") ?? string.Empty;

    private async Task GetImageAsync()
    {
        foreach (var player in Model)
        {
            var team = TeamsResponse.Teams.Data.FirstOrDefault(t => t.Id == player.TeamId);
            player.TeamName = team.TeamName;
            var league = LeaguesResponse.Leagues.FirstOrDefault(t => t.Id == team.LeagueId);
            player.Sport = league.Sport;
            player.Image = await ImageService.GetPlayerImageAsync(league, team, player);
        }
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }
}
