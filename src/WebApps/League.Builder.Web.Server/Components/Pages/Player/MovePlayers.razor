@page "/moveplayers/{id}"
@using League.Builder.Web.Server.Services.Cache
@inject ILeagueService LeagueService
@inject ITeamService TeamService
@inject IPlayerService PlayerService
@inject IAWSService AWSService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavManager
@inject ErrorState ErrorState
@inject ILeagueLocalCacheService LeagueLocalCache
@inject ITeamLocalCacheService TeamLocalCache
@inject IPlayerLocalCacheService PlayerLocalCache
@inject IJSRuntime JsRuntime
@inject KeycloakTokenService KeycloakTokenService
@inject ImageService ImageService

<AuthorizeView Roles="@String.Concat(Roles.UpdatePlayers)" Context="auth">
    <Authorized>
        @if (PageLoad)
        {
            <MudItem Class="pt-12">
                <MudExpansionPanels Class="border border-solid" Style="border-color: #000000">
                    <MudExpansionPanel Expanded="expandSearchPanel">
                        <TitleContent>
                            <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight:bold">Move Players</MudText>
                        </TitleContent>
                        <ChildContent>
                            <MudItem>
                                <MudStack Row="true">
                                    <MudItem xs="8">
                                        <MudSelect Class="mt-3" Label="Team" @bind-Value="SelectedTeamId">
                                            @TeamOptions
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="4" Style="align-content: center">
                                        <MudButton OnClick="GetTeamPlayers" 
                                                   Variant="Variant.Filled" 
                                                   Color="Color.Primary" 
                                                   Class="ml-auto" 
                                                   Style="width: 200px;">
                                                   Search
                                        </MudButton>
                                    </MudItem>
                                </MudStack>
                            </MudItem>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            <MudItem Class="mt-6">
                <MudPaper Class="border border-solid p-6" Style="border-color: #000000;">
                    <MudDropContainer T="DropItem" 
                                      Items="Items" 
                                      ItemsSelector="@((item, dropzone) => item.Identifier == dropzone)" 
                                      ItemDropped="ItemUpdated" 
                                      Class="d-flex flex-wrap flex-grow-1 border border-solid" 
                                      Style="border-color: #000000">
                        <ChildContent>
                            @TeamDropZone(TeamModel.Team)
                            @TeamDropZone(SelectedTeamModel.Team)
                        </ChildContent>
                        <ItemRenderer>
                            @PlayerCard(context)
                        </ItemRenderer>
                    </MudDropContainer>
                    <MudStack Class="mt-6" AlignItems="AlignItems.End">
                        <MudButton OnClick="SubmitTrade" 
                                   Variant="Variant.Filled" 
                                   Color="Color.Primary"
                                   Class="ml-auto" 
                                   Style="width: 200px;">
                                   Submit
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
        else
        {
            <Loading />
        }
    </Authorized>
    <NotAuthorized>
        <NoAccess />
    </NotAuthorized>
</AuthorizeView>


@code {
    [Parameter]
    public string Id { get; set; }
    private GetLeagueByIdResponse LeagueModel {get; set;} = default!;
    private GetTeamsByLeagueResponse TeamsByLeagueModel {get; set;} = default!;
    private GetTeamByIdResponse TeamModel {get; set;} = default!;
    private GetTeamByIdResponse SelectedTeamModel {get; set;} = default!;
    private IEnumerable<TeamModel> LeagueTeamsModel {get; set;} = default!;
    private GetPlayersByTeamResponse PlayerModel {get; set;} = default!;
    private GetPlayersByTeamResponse SelectedTeamPlayerModel {get; set;} = default!;
    private List<DropItem> Items = new();
    private bool PageLoad = false;
    private bool expandSearchPanel = true;
    private Guid SelectedTeamId;
    private List<Guid> SelectedPlayerIds = new();
    private IJSObjectReference? _module;

    private IEnumerable<TeamModel> OtherTeams =>
        TeamsByLeagueModel?.Teams.Where(t => t.Id != TeamModel.Team.Id) ?? Enumerable.Empty<TeamModel>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAllAsync();
            PageLoad = true;

        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task LoadAllAsync()
    {
        var teamId = Guid.Parse(Id);

        TeamModel = await LoadTeamAsync(teamId);

        PlayerModel = await LoadPlayersAsync(teamId);

        LeagueModel = await LoadLeagueAsync(TeamModel.Team.LeagueId);

        TeamsByLeagueModel = await LoadTeamsByLeagueAsync(LeagueModel.League.Id);

        LeagueTeamsModel = TeamsByLeagueModel.Teams.Where(x => x.Id != TeamModel.Team.Id);

        await LoadImagesAsync(PlayerModel.Players, TeamModel.Team);

        SelectedTeamId = LeagueTeamsModel.OrderBy(x => x.TeamName).First().Id;

        await LoadSelectedTeamAsync();

        BuildDropZone(PlayerModel.Players, TeamModel.Team);
        BuildDropZone(SelectedTeamPlayerModel.Players, SelectedTeamModel.Team);

    }

    private async Task LoadSelectedTeamAsync()
    {
        SelectedTeamModel = await LoadTeamAsync(SelectedTeamId);

        SelectedTeamPlayerModel = await LoadPlayersAsync(SelectedTeamId);

        await LoadImagesAsync(SelectedTeamPlayerModel.Players, SelectedTeamModel.Team);
    }

    private Task<GetTeamByIdResponse> LoadTeamAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamByIdCache(id.ToString()),
            () => TeamService.GetTeamById(id),
            (t) => TeamLocalCache.SetTeamByIdCache(id.ToString(), t)
        );

    private Task<GetPlayersByTeamResponse> LoadPlayersAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayersByTeamCache(id.ToString()),
            () => PlayerService.GetPlayersByTeam(id),
            (p) => PlayerLocalCache.SetPlayersByTeamCache(id.ToString(), p)
        );

    private Task<GetLeagueByIdResponse> LoadLeagueAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => LeagueLocalCache.GetLeagueByIdCache(id.ToString()),
            () => LeagueService.GetLeague(id),
            (l) => LeagueLocalCache.SetLeagueByIdCache(id.ToString(), l)
        );

    private Task<GetTeamsByLeagueResponse> LoadTeamsByLeagueAsync(Guid id) =>
        DataLoader.GetOrLoad(
            () => TeamLocalCache.GetTeamsByLeagueCache(id.ToString()),
            () => TeamService.GetTeamsByLeague(id),
            (t) => TeamLocalCache.SetTeamsByLeagueCache(id.ToString(), t)
        );

    private void ItemUpdated(MudItemDropInfo<DropItem> dropItem)
    {
        dropItem.Item.PreviousTeam = dropItem.Item.Identifier;
        dropItem.Item.Identifier = dropItem.DropzoneIdentifier;
        dropItem.Item.Selected = true;
        SelectedPlayerIds.Add(dropItem.Item.Id);
    }

    private List<DropItem> BuildDropZone(IEnumerable<PlayerModel> players, TeamModel team)
    {
        foreach (var p in players)
        {
            Items.Add(new DropItem
                { 
                    Id = p.Id, 
                    PlayerImage = p.Image, 
                    Name = $"{p.FirstName} {p.LastName}", 
                    Identifier = team.TeamName, 
                    PreviousTeam = string.Empty, 
                    Selected = false 
                });
        }

        return Items;
    }

    private void RemoveTeamItems(TeamModel team)
    {
        foreach (var player in Items.Where(x => x.Selected == true))
        {
            player.Selected = false;
            player.Identifier = player.PreviousTeam;
            player.PreviousTeam = string.Empty;
        }
        Items.RemoveAll(x => x.Identifier == team.TeamName);
    }

    private async Task LoadImagesAsync(IEnumerable<PlayerModel> players, TeamModel team)
    {
        foreach (var player in players)
            player.Image = await ImageService.GetPlayerImageAsync(LeagueModel.League, team, player);

        team.Image = await ImageService.GetTeamImageAsync(LeagueModel.League, team);
    }

    private async Task GetTeamPlayers()
    {
        try
        {
            PageLoad = false;
            RemoveTeamItems(SelectedTeamModel.Team);

            await LoadSelectedTeamAsync();

            BuildDropZone(SelectedTeamPlayerModel.Players, SelectedTeamModel.Team);
            PageLoad = true;

        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private async Task SubmitTrade()
    {
        try
        {    
            var selected = Items.Where(x => x.Selected == true);
            foreach (var item in selected)
                await ProcessPlayerTransferAsync(item);
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }

    }

    private async Task ProcessPlayerTransferAsync(DropItem item)
    {
        var response = await DataLoader.GetOrLoad(
            () => PlayerLocalCache.GetPlayerByIdCache(item.Id.ToString()),
            () => PlayerService.GetPlayerById(item.Id),
            (p) => PlayerLocalCache.SetPlayerByIdCache(p, item.Id.ToString())
        );

        var newTeam = item.Identifier == TeamModel.Team.TeamName ? TeamModel.Team : SelectedTeamModel.Team;
        var oldTeam = item.PreviousTeam == TeamModel.Team.TeamName ? TeamModel.Team : SelectedTeamModel.Team;

        await CopyPlayerImageAsync(response.Player, oldTeam, newTeam);
        await UpdatePlayerTeamAsync(response.Player, newTeam);
        await ClearCache(newTeam, oldTeam);
    }

    private async Task CopyPlayerImageAsync(PlayerModel player, TeamModel oldTeam, TeamModel newTeam)
        => await ImageService.CopyPlayerImageAsync(LeagueModel.League, oldTeam, newTeam, player);

    private async Task UpdatePlayerTeamAsync(PlayerModel player, TeamModel newTeam)
    {
        var updatePlayer = new UpdatePlayerRecord(
            player.Id,
            newTeam.Id,
            player.FirstName,
            player.LastName,
            player.PlayerAddress,
            player.PlayerDetail,
            player.Description,
            player.ImageFile,
            (int)player.PlayerStatus
        );

        await PlayerService.UpdatePlayer(new UpdatePlayerRequest(updatePlayer));
    }

    private async Task ClearCache(TeamModel team, TeamModel previousTeam)
    {
        await PlayerLocalCache.DeletePlayersCache();
        await PlayerLocalCache.DeletePlayersByFirstNameCache();
        await PlayerLocalCache.DeletePlayersByLastNameCache();
        await PlayerLocalCache.DeletePlayersByPositionCache();
        await PlayerLocalCache.DeletePlayersByBirthDateCache();
        await PlayerLocalCache.DeletePlayersBeforeBirthDateCache();
        await PlayerLocalCache.DeletePlayersAfterBirthDateCache();
        await PlayerLocalCache.DeletePlayersByTeamCache(team.Id.ToString());
        await PlayerLocalCache.DeletePlayersByTeamCache(previousTeam.Id.ToString());
    }

    private async Task HandleError(Exception ex)
    {
        if (KeycloakTokenService.ShouldForceLogout())
        {
            _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/authRefresh.js");
            await _module.InvokeVoidAsync("logout");
        }
        ErrorState.Message = ex.Message;
        NavManager.NavigateTo("/error");
    }


    private RenderFragment TeamOptions => __builder =>
    {
        foreach (var team in OtherTeams)
        {
            <MudSelectItem Value="@team.Id">@team.TeamName</MudSelectItem>
            ;
        }
    };

    private RenderFragment<TeamModel> TeamDropZone => team =>@<MudDropZone T="DropItem" Identifier="@team.TeamName" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1">
            <MudStack Row="true">
                <MudAvatar Size="Size.Small">
                    <MudImage Src="@team.Image" Alt="Team Image" />
                </MudAvatar>
            <MudText Typo="Typo.h5" Class="mb-4">@team.TeamName</MudText>
            </MudStack>
        </MudDropZone>
    ;

    private RenderFragment<DropItem> PlayerCard => item =>@<MudPaper Elevation="25" Class="pa-4 my-4">
        <MudStack Row="true">
            <MudAvatar Size="Size.Small">
                <MudImage Src="@item.PlayerImage" Alt="Player Image" />
            </MudAvatar>
            <MudText Typo="Typo.body1">
                @item.Name
            </MudText>
        </MudStack>
    </MudPaper>;

    public class DropItem
    {
        public Guid Id { get; set; }
        public string PlayerImage { get; set; } = default!;
        public string Name { get; init; } = default!;
        public string Identifier { get; set; } = default!;
        public string PreviousTeam { get; set; } = default!;
        public bool Selected { get; set; }
    }
}
